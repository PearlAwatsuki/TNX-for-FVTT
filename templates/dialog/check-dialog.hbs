{{#if noPending}}
<div class="check-no-pending">判定情報がありません。</div>
{{else}}
<div class="check-dialog-body">

    <div class="check-header">
        <span class="check-type-label">{{typeLabel}}</span>
        <span class="check-skill-label">{{skillLabel}}</span>
    </div>

    <div class="check-suits">
        {{#each validSuits as |s|}}
        <span class="check-suit-badge suit-{{s.key}}" title="{{s.name}}">{{s.symbol}}</span>
        {{/each}}
    </div>

    {{#if hasTargetValue}}
    <div class="check-tn">
        <span class="check-tn-label">目標値</span>
        <span class="check-tn-value">{{targetValue}}</span>
    </div>
    {{/if}}

    <p class="check-hint">{{hint}}</p>

    <footer class="check-dialog-footer">
        <button type="button" class="tnx-btn" data-action="drawFromDeck">
            <i class="fas fa-cards-blank"></i> 山札から判定
        </button>
        {{#if hasTrump}}
        <button type="button" class="tnx-btn {{#if trumpMode}}active{{/if}}" data-action="toggleTrumpMode">
            <i class="fas fa-star"></i> 切り札を使う
        </button>
        {{/if}}
        <button type="button" class="tnx-btn" data-action="cancel">
            <i class="fas fa-times"></i> キャンセル
        </button>
    </footer>

</div>
{{/if}}
