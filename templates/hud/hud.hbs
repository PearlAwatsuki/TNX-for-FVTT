<div class="tnx-hud">
    <div class="hud-container hud-right-column">
        <button class="hud-collapse-toggle hud-collapse-right" data-action="toggleHudColumn" data-column="right" title="右カラムを折りたたむ">
            <i class="fas fa-chevron-right"></i>
        </button>
        <div class="main-area neuro-area">
            <span class="card-slot-label">シーンカード</span>
            <div class="neuro-cards-row">
                <div class="card-slot">
                    {{#if (and neuroDeck neuroDeck.count)}}
                        <div class="deck-card" data-action="drawNeuro" title="ニューロデッキ (クリックでシーンカードを引く)" draggable="true" data-drag-type="neuro-deck">
                            <img src="{{neuroDeck.img}}" alt="ニューロデッキ">
                            <span class="deck-count">{{neuroDeck.count}}</span>
                        </div>
                    {{else}}
                        <div class="card-empty-placeholder">
                            <i class="fas fa-inbox"></i>
                        </div>
                    {{/if}}
                </div>

                <div class="card-slot">
                    {{#if (and scenePile scenePile.cards.size)}}
                        <div class="deck-card scene-card-display" data-drop-zone="scene">
                            <img src="{{topSceneCard.img}}" alt="{{topSceneCard.name}}">
                        </div>
                    {{else}}
                        <div class="card-empty-placeholder" data-drop-zone="scene">
                            <i class="fas fa-cards-blank"></i>
                        </div>
                    {{/if}}
                </div>
            </div>
        </div>

        <div class="hud-panel hud-insert-area">
            <span class="card-slot-label">情報項目</span>
        </div>

        {{#if showPlayerHands}}
        <div class="hud-panel player-hands-area">
            <span class="card-slot-label">プレイヤーの手札</span>
            <div class="player-hands-scroll">
                {{#if playerHands}}
                    {{#each playerHands as |ph|}}
                        <div class="player-hand-row" data-action="giveCardsToPlayer" data-target-user-id="{{ph.userId}}" title="{{ph.userName}} にカードを渡す">
                            <span class="player-hand-name" style="color: {{ph.color}}">{{ph.userName}}</span>
                            <div class="player-hand-cards">
                                {{#if ph.cards.length}}
                                    {{#each ph.cards as |card|}}
                                        <img class="player-hand-card-img" src="{{card.img}}" alt="{{card.name}}" title="{{card.name}}">
                                    {{/each}}
                                {{else}}
                                    <span class="player-hand-empty">（手札なし）</span>
                                {{/if}}
                            </div>
                        </div>
                    {{/each}}
                {{else}}
                    <span class="player-hand-empty">（対象プレイヤーなし）</span>
                {{/if}}
            </div>
        </div>
        {{/if}}

        <div class="main-area">
            <div class="card-slot">
                <span class="card-slot-label">山札</span>
                {{#if (and cardDeck cardDeck.count)}}
                    <div class="deck-card deck-area" data-action="drawFromDeck" title="山札からドロー" draggable="true" data-drag-type="deck">
                        <img src="{{cardDeck.img}}" alt="山札">
                        <span class="deck-count">{{cardDeck.count}}</span>
                    </div>
                {{else}}
                    <div class="card-empty-placeholder deck-area">
                        <i class="fas fa-inbox"></i>
                    </div>
                {{/if}}
            </div>

            <div class="card-slot">
                <span class="card-slot-label">捨て札</span>
                {{#if (and discardPile discardPile.cards.size)}}
                    <div class="deck-card discard-area" data-action="takeFromDiscard" title="{{discardPile.name}}" draggable="true" data-drag-type="discard-card" data-drop-zone="discard">
                        <img src="{{topDiscardImage}}" alt="捨て札">
                        <span class="deck-count">{{discardPile.cards.size}}</span>
                    </div>
                {{else}}
                    <div class="card-empty-placeholder discard-area" data-drop-zone="discard">
                        <i class="fas fa-trash"></i>
                    </div>
                {{/if}}
            </div>
        </div>
    </div>

    <div class="hud-container hud-bottom-bar">
        {{#if accessCards}}
        <div class="access-area hud-panel">
            <div class="access-area-header" data-action="toggleAccessArea" title="アクセスカードの表示を開閉">
                <i class="fas fa-chevron-down access-fold-icon"></i>
                <span class="card-slot-label">アクセスカード</span>
            </div>
            <div class="access-cards-row">
                {{#each accessCards as |card|}}
                    <div class="access-card" data-action="presentAccessCard" data-card-id="{{card.id}}" title="{{card.name}} (クリックで全員に提示)">
                        <img src="{{card.img}}" alt="{{card.name}}">
                    </div>
                {{/each}}
            </div>
        </div>
        {{/if}}

        <div class="hud-bottom-main">
            <div class="hud-bottom-content">
                <div class="hand-area hud-panel" data-drop-zone="hand">
                    <span class="card-slot-label">手札</span>
                    <div class="hand-cards-row">
                        {{#if (and hand hand.cards.size)}}
                            {{#each hand.cards as |card|}}
                                <div class="card-in-hand" data-action="playCard" data-card-id="{{card.id}}" title="{{card.name}} (クリックでプレイ)" draggable="true" data-drag-type="hand-card">
                                    <img src="{{card.img}}" alt="{{card.name}}">
                                </div>
                            {{/each}}
                        {{else}}
                            <div class="card-empty-placeholder" title="手札">
                                <i class="fas fa-hand-paper"></i>
                            </div>
                        {{/if}}
                    </div>
                </div>
            </div>

            <div class="trump-area hud-panel">
                <div class="card-slot">
                    <span class="card-slot-label">切り札</span>
                    {{#if trumpCard}}
                        <div class="card-in-hand" data-action="useTrump" data-card-id="{{trumpCard.id}}" title="{{trumpCard.name}} (クリックで使用)" draggable="true" data-drag-type="trump-card">
                            <img src="{{trumpCard.img}}" alt="{{trumpCard.name}}">
                        </div>
                    {{else}}
                        <div class="card-empty-placeholder" title="切り札">
                            <i class="fas fa-star"></i>
                        </div>
                    {{/if}}
                </div>
            </div>

            <button class="hud-collapse-toggle hud-collapse-bottom" data-action="toggleHudColumn" data-column="bottom" title="HUD / ホットバーを切り替え">
                <i class="fas fa-chevron-left"></i>
            </button>
        </div>
    </div>
</div>
