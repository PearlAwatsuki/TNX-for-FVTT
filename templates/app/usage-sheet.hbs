<div class="tnx-usage-sheet-inner">

    {{!-- ヘッダー: 種別バッジ + 名前 --}}
    <header class="usage-sheet-header">
        <span class="usage-type-badge usage-type--{{usage.type}}">{{typeLabel}}</span>
        <input class="usage-name-input" type="text" name="name"
               value="{{usage.name}}" placeholder="用途名"
               {{#unless editable}}disabled{{/unless}}>
    </header>

    {{!-- タブナビゲーション: 基本 / 発動 / 効果 --}}
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-action="tab" data-group="primary" data-tab="identity">基本</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="activation">発動</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="effects">効果</a>
    </nav>

    <section class="sheet-body usage-sheet-body">

        {{!-- ① 基本タブ: 説明 --}}
        <div class="tab" data-group="primary" data-tab="identity">
            <div class="usage-form-section">
                <label class="usage-field-label">説明</label>
                <textarea class="usage-textarea" name="description" rows="8"
                          placeholder="（省略可）"
                          {{#unless editable}}disabled{{/unless}}>{{usage.description}}</textarea>
            </div>
        </div>

        {{!-- ② 発動タブ: タイミング・対象・射程・目標値・対決 --}}
        <div class="tab" data-group="primary" data-tab="activation">
            <div class="usage-form-grid">

                {{!-- タイミング --}}
                <div class="usage-form-row">
                    <label class="usage-field-label">タイミング</label>
                    <select name="timing.value" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions skillOpts.timing selected=usage.timing.value}}
                    </select>
                </div>
                <div class="usage-form-row timing-action-sub">
                    <label class="usage-field-label">アクション種別</label>
                    <select name="timing.actionName" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions skillOpts.actions selected=usage.timing.actionName}}
                    </select>
                </div>
                <div class="usage-form-row timing-process-sub">
                    <label class="usage-field-label">プロセス種別</label>
                    <select name="timing.processName" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions skillOpts.processes selected=usage.timing.processName}}
                    </select>
                </div>
                <div class="usage-form-row timing-other-sub">
                    <label class="usage-field-label">タイミング（自由入力）</label>
                    <input type="text" name="timing.timingOther"
                           value="{{usage.timing.timingOther}}"
                           {{#unless editable}}disabled{{/unless}}>
                </div>

                {{!-- 対象（変更不可※をインライン） --}}
                <div class="usage-form-row">
                    <label class="usage-field-label">対象</label>
                    <div class="usage-field-with-fixed">
                        <select name="target" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions skillOpts.target selected=usage.target}}
                        </select>
                        <label class="usage-fixed-toggle" title="変更不可（※）：効果による対象変更を受けない">
                            <input type="checkbox" name="isFixedTarget" {{checked usage.isFixedTarget}}
                                   {{#unless editable}}disabled{{/unless}}><span>※</span>
                        </label>
                    </div>
                </div>
                <div class="usage-form-row target-other-sub">
                    <label class="usage-field-label">対象（自由入力）</label>
                    <input type="text" name="targetOther" value="{{usage.targetOther}}"
                           {{#unless editable}}disabled{{/unless}}>
                </div>

                {{!-- 射程（変更不可※をインライン） --}}
                <div class="usage-form-row">
                    <label class="usage-field-label">射程</label>
                    <div class="usage-field-with-fixed">
                        <select name="range" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions skillOpts.range selected=usage.range}}
                        </select>
                        <label class="usage-fixed-toggle" title="変更不可（※）：効果による射程変更を受けない">
                            <input type="checkbox" name="isFixedRange" {{checked usage.isFixedRange}}
                                   {{#unless editable}}disabled{{/unless}}><span>※</span>
                        </label>
                    </div>
                </div>
                <div class="usage-form-row range-other-sub">
                    <label class="usage-field-label">射程（自由入力）</label>
                    <input type="text" name="rangeOther" value="{{usage.rangeOther}}"
                           {{#unless editable}}disabled{{/unless}}>
                </div>

                {{!-- 目標値 --}}
                <div class="usage-form-row">
                    <label class="usage-field-label">目標値</label>
                    <select name="targetValue" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions skillOpts.targetValue selected=usage.targetValue}}
                    </select>
                </div>
                <div class="usage-form-row tv-number-sub">
                    <label class="usage-field-label">目標値（数字）</label>
                    <div class="number-input-spinner">
                        <button type="button" data-action="decrementTargetValue" class="tnx-btn" {{#unless editable}}disabled{{/unless}}>-</button>
                        <input type="number" name="targetValueNumber" value="{{usage.targetValueNumber}}"
                               {{#unless editable}}disabled{{/unless}}>
                        <button type="button" data-action="incrementTargetValue" class="tnx-btn" {{#unless editable}}disabled{{/unless}}>+</button>
                    </div>
                </div>
                <div class="usage-form-row tv-other-sub">
                    <label class="usage-field-label">目標値（自由入力）</label>
                    <input type="text" name="targetValueOther" value="{{usage.targetValueOther}}"
                           {{#unless editable}}disabled{{/unless}}>
                </div>

                {{!-- 対決不可（インライントグル） --}}
                <div class="usage-form-row usage-toggle-row">
                    <label class="usage-toggle-inline" title="対象がこの判定に対決（リアクション）できない状態">
                        <input type="checkbox" name="isUnopposable" {{checked usage.isUnopposable}}
                               {{#unless editable}}disabled{{/unless}}>
                        <span>対決不可</span>
                    </label>
                </div>

            </div>

            {{!-- 技能ベース用途のみ: 対決可能技能の情報表示 ＋ 自動入力 --}}
            {{#if showSkillParams}}
            <div class="usage-form-section usage-confrontation-info">
                <label class="usage-field-label">対決（参加技能より）</label>
                {{#if confrontationCannot}}
                <p class="usage-info-line"><i class="fas fa-ban"></i> 対決不可の技能を含みます</p>
                {{/if}}
                {{#if confrontationReactions.length}}
                <p class="usage-info-line">リアクション例: {{#each confrontationReactions}}<span class="usage-info-tag">{{this}}</span>{{/each}}</p>
                <p class="usage-empty-hint">※例示であり、これ以外のリアクションを排除するものではありません（※付きは必須）。</p>
                {{else}}
                {{#unless confrontationCannot}}
                <p class="usage-empty-hint">（参加技能に対決の指定なし）</p>
                {{/unless}}
                {{/if}}
            </div>
            {{#if editable}}
            <div class="usage-autofill-row">
                <a class="tnx-btn tnx-btn--sm" data-action="autoFill" title="参加技能の固有値から発動パラメータを優先度で自動入力します">
                    <i class="fas fa-wand-magic-sparkles"></i> 参加技能から自動入力
                </a>
            </div>
            {{/if}}
            {{/if}}
        </div>

        {{!-- ③ 効果タブ: 種別固有設定 ＋ 適用される効果 --}}
        <div class="tab" data-group="primary" data-tab="effects">

            {{!-- check: ベース技能・組み合わせ技能 --}}
            {{#if isCheckType}}
            {{> "systems/tokyo-nova-axleration/templates/app/usage-sheet-combo.hbs"}}
            {{/if}}

            {{!-- attack: ベース技能・武器・ダメージ種別・組み合わせ技能 --}}
            {{#if isAttackType}}
            <div class="usage-form-grid">
                <div class="usage-form-row">
                    <label class="usage-field-label">使用武器</label>
                    <select name="weaponRef.itemId" {{#unless editable}}disabled{{/unless}}>
                        <option value="">── 選択 ──</option>
                        {{#each availableWeapons}}
                        <option value="{{this.id}}" {{#if (eq this.id ../usage.weaponRef.itemId)}}selected{{/if}}>{{this.name}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="usage-form-row">
                    <label class="usage-field-label">ダメージ種別</label>
                    <select name="damageType" {{#unless editable}}disabled{{/unless}}>
                        <option value="">── 選択 ──</option>
                        <option value="S" {{#if (eq usage.damageType "S")}}selected{{/if}}>S（斬撃）</option>
                        <option value="P" {{#if (eq usage.damageType "P")}}selected{{/if}}>P（貫通）</option>
                        <option value="I" {{#if (eq usage.damageType "I")}}selected{{/if}}>I（衝撃）</option>
                    </select>
                </div>
            </div>
            {{> "systems/tokyo-nova-axleration/templates/app/usage-sheet-combo.hbs"}}
            {{/if}}

            {{!-- damageBoost / damageReduce: 計算式・カテゴリ --}}
            {{#if isDamageType}}
            <div class="usage-form-grid">
                <div class="usage-form-row">
                    <label class="usage-field-label">効果量（計算式）</label>
                    <input type="text" name="formula" value="{{usage.formula}}"
                           placeholder="例: @card, @card + 3, 5"
                           {{#unless editable}}disabled{{/unless}}>
                </div>
                <div class="usage-form-row">
                    <label class="usage-field-label">適用カテゴリ</label>
                    <select name="damageCategory" {{#unless editable}}disabled{{/unless}}>
                        <option value="">── 選択 ──</option>
                        <option value="physical" {{#if (eq usage.damageCategory "physical")}}selected{{/if}}>物理</option>
                        <option value="mental"   {{#if (eq usage.damageCategory "mental")}}selected{{/if}}>精神</option>
                    </select>
                </div>
            </div>
            {{/if}}

            {{!-- modification: 改造可能パラメータ --}}
            {{#if isModificationType}}
            <div class="usage-form-section">
                <label class="usage-field-label">改造可能パラメータ</label>
                <div class="usage-param-list">
                    {{#each usage.modifiableParams}}
                    <div class="usage-param-row">
                        <span class="usage-param-name">{{this}}</span>
                        {{#if ../editable}}
                        <a class="usage-icon-btn" data-action="paramDelete" data-idx="{{@index}}"
                           title="削除"><i class="fas fa-times"></i></a>
                        {{/if}}
                    </div>
                    {{else}}
                    <p class="usage-empty-hint">（なし）</p>
                    {{/each}}
                </div>
                {{#if editable}}
                <div class="usage-param-add">
                    <input class="param-input" type="text" placeholder="パラメータ名">
                    <a class="tnx-btn tnx-btn--sm" data-action="paramAdd">
                        <i class="fas fa-plus"></i> 追加
                    </a>
                </div>
                {{/if}}
            </div>
            {{/if}}

            {{!-- 適用される効果（ActiveEffect） --}}
            <div class="usage-form-section usage-effects-section">
                <label class="usage-field-label usage-section-head">適用される効果</label>
                <div class="usage-effect-list">
                    {{#each addedEffects}}
                    <div class="usage-skill-ref-row">
                        <span class="usage-skill-ref-name">{{this.name}}</span>
                        {{#if ../editable}}
                        <a class="usage-icon-btn" data-action="effectRemove" data-effect-id="{{this.id}}"
                           title="解除"><i class="fas fa-times"></i></a>
                        {{/if}}
                    </div>
                    {{else}}
                    <p class="usage-empty-hint">（適用される効果なし）</p>
                    {{/each}}
                </div>
                {{#if editable}}
                <div class="usage-skill-ref-add">
                    <select class="effect-select">
                        <option value="">── 追加する効果を選択 ──</option>
                        {{#each availableEffects}}
                        <option value="{{this.id}}">{{this.name}}</option>
                        {{/each}}
                    </select>
                </div>
                {{#unless hasAnyEffect}}
                <p class="usage-empty-hint">このアイテムに ActiveEffect がありません。<br>
                   アイテムシートの「エフェクト」タブで追加すると、ここで選択できます。</p>
                {{/unless}}
                {{/if}}
            </div>

        </div>

    </section>
</div>
