<div class="tnx-item-list">
    <div class="tnx-item-list__row tnx-item-list__row--header">
        <div class="tnx-item-list__column--main">用途一覧</div>
        <div class="tnx-item-list__column--controls">
            <a class="action-create" title="用途を追加">
                <i class="fas fa-plus"></i>
            </a>
        </div>
    </div>

    <ol class="item-list-body">
        {{#each system.actions as |action|}}
            <li class="tnx-item-list__row">
                <div class="tnx-item-list__column--main">
                    <span class="usage-type-tag usage-type--{{action.type}}">{{lookup ../options.usageTypeLabels action.type}}</span>
                    <h4>{{action.name}}</h4>
                </div>
                <div class="tnx-item-list__column--controls">
                    {{#if action.effects.length}}
                    <a class="action-use" data-usage-id="{{action._id}}" title="使用（効果を有効化）">
                        <i class="fas fa-bolt"></i>
                    </a>
                    {{/if}}
                    <a class="action-edit" data-action="edit" data-usage-id="{{action._id}}" title="編集">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a class="action-delete" data-action="delete" data-usage-id="{{action._id}}" title="削除">
                        <i class="fas fa-trash"></i>
                    </a>
                </div>
            </li>
        {{/each}}
    </ol>
</div>
