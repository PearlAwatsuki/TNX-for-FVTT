<div class="record-sheet-body">

  {{!-- 経験点サマリ --}}
  <div class="record-exp-summary">
    <div class="exp-item">
      <span class="exp-label">合計経験点</span>
      <span class="exp-value record-exp-value" data-exp-field="total">{{exp.total}}</span>
    </div>
    <div class="exp-item">
      <span class="exp-label">使用可能</span>
      <span class="exp-value record-exp-value" data-exp-field="value">{{exp.value}}</span>
    </div>
    <div class="exp-item">
      <span class="exp-label">消費済み</span>
      <span class="exp-value record-exp-value" data-exp-field="spent">{{exp.spent}}</span>
    </div>
  </div>

  {{!-- 経験点履歴 --}}
  <div class="record-history-section">
    <h3 class="record-section-title">経験点履歴</h3>

    <div class="history-list-wrapper">
      <div class="history-header history-grid">
        <div class="cell cell-date">日付</div>
        <div class="cell cell-title">シナリオ名</div>
        <div class="cell cell-exp">経験点</div>
        <div class="cell cell-rl">RL</div>
        <div class="cell cell-players">参加プレイヤー</div>
        {{#if isEditMode}}
          <div class="cell cell-ctrl">
            <button type="button" data-action="addHistory" class="tnx-ring-btn" title="追加">
              <i class="fas fa-plus"></i>
            </button>
          </div>
        {{/if}}
      </div>
      <ol class="history-list">
        {{#each history as |entry i|}}
        <li class="item history-row history-grid">
          <div class="cell cell-date">
            {{#if ../isEditMode}}
              <input type="date" class="history-input" data-id="{{entry.id}}" data-field="date" value="{{entry.date}}">
            {{else}}
              <span class="squeeze-text">{{entry.date}}</span>
            {{/if}}
          </div>
          <div class="cell cell-title">
            {{#if ../isEditMode}}
              <input type="text" class="history-input" data-id="{{entry.id}}" data-field="title" value="{{entry.title}}" placeholder="シナリオ名">
            {{else}}
              <span class="squeeze-text">{{entry.title}}</span>
            {{/if}}
          </div>
          <div class="cell cell-exp">
            {{#if ../isEditMode}}
              <input type="number" class="history-input" data-id="{{entry.id}}" data-field="exp" value="{{entry.exp}}">
            {{else}}
              <span class="squeeze-text">{{entry.exp}}</span>
            {{/if}}
          </div>
          <div class="cell cell-rl">
            {{#if ../isEditMode}}
              <input type="text" class="history-input" data-id="{{entry.id}}" data-field="rl" value="{{entry.rl}}">
            {{else}}
              <span class="squeeze-text">{{entry.rl}}</span>
            {{/if}}
          </div>
          <div class="cell cell-players">
            {{#if ../isEditMode}}
              <input type="text" class="history-input" data-id="{{entry.id}}" data-field="players" value="{{entry.players}}" placeholder="参加プレイヤー">
            {{else}}
              <span class="squeeze-text">{{entry.players}}</span>
            {{/if}}
          </div>
          {{#if ../isEditMode}}
            <div class="cell cell-ctrl">
              <button type="button" data-action="deleteHistory" class="tnx-ring-btn" data-id="{{entry.id}}" title="削除">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          {{/if}}
        </li>
        {{/each}}
      </ol>
    </div>
  </div>

</div>
