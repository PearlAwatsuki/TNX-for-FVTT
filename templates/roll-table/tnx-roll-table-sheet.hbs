<div class="tnx-roll-table-body">

    {{!-- モード切替 --}}
    <div class="tnx-rt-mode-bar">
        <label class="tnx-rt-mode-radio {{#unless isConfiguredMode}}active{{/unless}}">
            <input type="radio" name="modeRadio" value="doc"
                {{#unless isConfiguredMode}}checked{{/unless}}>
            仮想 DoC
        </label>
        <label class="tnx-rt-mode-radio {{#if isConfiguredMode}}active{{/if}}">
            <input type="radio" name="modeRadio" value="configured"
                {{#if isConfiguredMode}}checked{{/if}}>
            設定デッキ
        </label>
    </div>

    {{!-- 仮想 DoC モード ─────────────────────────────── --}}
    {{#unless isConfiguredMode}}
    <div class="tnx-rt-doc-section">
        <p class="tnx-rt-hint">
            54 枚フルデッキ（Joker×2、各数値×4）から仮想ドローし、チャットに結果を出力します。
        </p>
        <div class="tnx-rt-slots">
            {{#each docEntries}}
            <div class="tnx-rt-slot-row">
                <span class="tnx-rt-slot-label">{{this.label}}</span>
                <input type="text"
                    name="system.docResults.{{this.key}}"
                    value="{{this.value}}"
                    placeholder="結果テキスト">
            </div>
            {{/each}}
        </div>
    </div>
    {{/unless}}

    {{!-- 設定デッキモード ─────────────────────────────── --}}
    {{#if isConfiguredMode}}
    <div class="tnx-rt-configured-section">
        <div class="tnx-rt-deck-selector form-group">
            <label>紐付けデッキ</label>
            <select name="system.deckId">
                {{#each deckOptions}}
                <option value="{{this.uuid}}"
                    {{#if (eq this.uuid ../system.deckId)}}selected{{/if}}>
                    {{this.name}}
                </option>
                {{/each}}
            </select>
        </div>
        <p class="tnx-rt-hint">
            HUD からこのデッキのカードが引かれると、カード名と一致するエントリの結果をチャットに出力します。
        </p>
        <div class="tnx-rt-entries">
            {{#each system.deckResults}}
            <div class="tnx-rt-entry-row" data-index="{{@index}}">
                <input type="text"
                    name="system.deckResults.{{@index}}.label"
                    value="{{this.label}}"
                    placeholder="カード名（部分一致）">
                <input type="text"
                    name="system.deckResults.{{@index}}.text"
                    value="{{this.text}}"
                    placeholder="結果テキスト">
                <button type="button" class="tnx-btn tnx-btn--icon"
                    data-action="removeEntry"
                    data-index="{{@index}}"
                    title="削除">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
            {{/each}}
        </div>
        <div class="tnx-rt-add-row">
            <button type="button" class="tnx-btn" data-action="addEntry">
                <i class="fas fa-plus"></i> エントリ追加
            </button>
        </div>
    </div>
    {{/if}}

    {{!-- フッター ─────────────────────────────────────── --}}
    <div class="tnx-rt-footer">
        {{#unless isConfiguredMode}}
        <button type="button" class="tnx-btn" data-action="drawDoc">
            <i class="fas fa-hand-sparkles"></i> ドロー
        </button>
        {{/unless}}
        <button type="submit" class="tnx-btn">
            <i class="fas fa-save"></i> 保存
        </button>
    </div>

</div>
