<section class="sheet-profile two-column-layout cast-sheet">
    <aside class="profile-sidebar column left-column cast-sidebar">
        <div class="portrait-section">
            <img class="profile-img" src="{{actor.img}}" data-action="editImage" title="{{actor.name}}"/>
        </div>
        <div class="sidebar-personal-data-group">
            <h3 class="tnx-section-title tnx-section-title--sm">パーソナルデータ</h3>
            <div class="personal-data-grid">
                <div class="personal-data-item">
                    <label data-en="AGE">年齢</label>
                    <input type="text" name="system.age" value="{{system.age}}"/>
                </div>
                <div class="personal-data-item">
                    <label data-en="GENDER">性別</label>
                    <input type="text" name="system.gender" value="{{system.gender}}"/>
                </div>
                <div class="personal-data-item">
                    <label data-en="DOB">誕生日</label>
                    <input type="text" name="system.birthday" value="{{system.birthday}}"/>
                </div>
                <div class="personal-data-item">
                    <label data-en="HEIGHT">身長</label>
                    <input type="text" name="system.height" value="{{system.height}}"/>
                </div>
                <div class="personal-data-item">
                    <label data-en="WEIGHT">体重</label>
                    <input type="text" name="system.weight" value="{{system.weight}}"/>
                </div>
                <div class="personal-data-item">
                    <label data-en="EYES">瞳の色</label>
                    <input type="text" name="system.eyes" value="{{system.eyes}}"/>
                </div>
                <div class="personal-data-item">
                    <label data-en="HAIR">髪の色</label>
                    <input type="text" name="system.hair" value="{{system.hair}}"/>
                </div>
                <div class="personal-data-item">
                    <label data-en="SKIN">肌の色</label>
                    <input type="text" name="system.skin" value="{{system.skin}}"/>
                </div>
            </div>
        </div>
        <div class="sidebar-bounty-group">
            {{#if isEditMode}}
                <div class="bounty-edit-row">
                    <span class="bounty-section-label">報酬点</span>
                    <div class="bounty-field">
                        <label>初期値</label>
                        <input type="number" value="{{mundaneTotalValue}}" disabled>
                    </div>
                    <span class="bounty-separator">+</span>
                    <div class="bounty-field">
                        <label>修正値</label>
                        <input type="number" name="system.bounty" value="{{system.bounty}}">
                    </div>
                </div>
            {{else}}
                <div class="bounty-view-panel">
                    <span class="bounty-view-label">報酬点</span>
                    <div class="bounty-total-row">
                        <i class="fas fa-coins bounty-coin-icon"></i>
                        <span class="bounty-total">{{effectiveBounty}}</span>
                    </div>
                </div>
            {{/if}}
        </div>
    </aside>

    <section class="main-content-area column right-column">
        <header class="sheet-header profile-header">
            <div class="header-content-wrapper">
                <div class="identity-section">
                    <div class="identity-view-mode">
                        {{#if system.handle}}
                            <span class="handle-quoted-block">
                                <span class="quote-mark">"</span>
                                <ruby class="handle-ruby-view">
                                    <rb>{{system.handle}}</rb>
                                    <rt>{{system.handle_ruby}}</rt>
                                </ruby>
                                <span class="quote-mark">"</span>
                            </span>
                        {{/if}}
                        {{#if actor.name}}
                            <ruby class="char-name-ruby-view">
                                <rb>{{actor.name}}</rb>
                                <rt>{{system.charaname_ruby}}</rt>
                            </ruby>
                        {{else}}
                            {{#unless system.handle}}
                                <span class="no-name-placeholder">名前未設定</span>
                            {{/unless}}
                        {{/if}}
                    </div>
                    <div class="identity-edit-mode">
                        <label>キャラクター名</label>
                        <div class="char-name-block-edit">
                            <input name="name" type="text" value="{{actor.name}}">
                            <input name="system.charaname_ruby" type="text" value="{{system.charaname_ruby}}">
                        </div>
                        <label>ハンドル</label>
                        <div class="handle-block-edit">
                            <input name="system.handle" type="text" value="{{system.handle}}">
                            <input name="system.handle_ruby" type="text" value="{{system.handle_ruby}}">
                        </div>
                    </div>
                </div>
                <div class="middle-header-section">
                    <div class="rank-affiliation-wrapper">
                        <div class="citizen-rank-block">
                            <div class="view-mode-rank">
                                <span class="view-mode-label">市民ランク：</span>
                                <span class="view-mode-value">{{system.citizenRank}}</span>
                            </div>
                            <div class="edit-mode-rank">
                                <label>市民ランク：</label>
                                <select name="system.citizenRank">
                                    {{#each citizenRankOptionsForSelect as |o|}}
                                        <option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                        <div class="affiliation-block">
                            <div class="view-mode-affiliation">
                                <span class="view-mode-label">所属：</span>
                                <span class="view-mode-value">{{affiliationDisplay}}</span>
                            </div>
                            <div class="edit-mode-affiliation">
                                <label>所属：</label>
                                {{#if equippedAffiliations.length}}
                                    {{#each equippedAffiliations as |item|}}
                                        <button type="button" class="item-button tnx-linked-btn" data-action="openItemSheet" data-item-id="{{item._id}}" data-context-menu="item-edit">
                                            <img src="{{item.img}}" class="tnx-linked-btn__icon"/>
                                            <span class="tnx-linked-btn__label">{{item.name}}</span>
                                        </button>
                                    {{/each}}
                                {{else}}
                                    <div class="tnx-import-box tnx-import-box--inline" data-drop-area="affiliation"><span>組織アイテムをここにドロップ</span></div>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                    <div class="view-mode-style-summary">
                        <span class="view-mode-label">スタイル：</span>
                        <span class="style-summary-items">
                            {{#each processedStylesForView as |s|}}
                                <a class="style-summary-item" data-item-id="{{s._id}}">{{s.repeatedName}}{{s.roleIndicatorDisplay}}</a>
                                {{#unless @last}}、{{/unless}}
                            {{/each}}
                        </span>
                    </div>
                    <div class="exp-display-section">
                        <div class="view-mode-exp">
                            <span>消費経験点：</span>
                            <span class="exp-value">{{system.exp.spent}}</span>
                        </div>
                        <div class="edit-mode-exp">
                            <div>
                                <label>消費経験点：</label>
                                <span>{{system.exp.spent}}</span>
                            </div>
                            <div>
                                <label>総経験点：</label>
                                <span>{{system.exp.total}}</span>
                            </div>
                            <div>
                                <label>追加経験点：</label>
                                <input type="number" name="system.exp.additional" value="{{system.exp.additional}}" class="exp-input">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="styles-and-miracle-section">
                    {{#if isEditMode}}
                    <div class="edit-mode-styles-miracle-block">
                        <div class="item-slots-row">
                            {{#each styleSlots as |slot|}}
                                <div class="style-slot" data-item-id="{{slot._id}}">
                                    <div class="style-slot-inner">
                                        {{#if slot.isEmpty}}
                                            <div class="tnx-import-box tnx-import-box--inline tnx-import-box--compact" data-drop-area="style"><span>スタイルをドロップ</span></div>
                                        {{else}}
                                            <button type="button" class="item-button tnx-linked-btn style-info-button" data-action="openItemSheet" data-item-id="{{slot._id}}" data-context-menu="item-edit">
                                                <img src="{{slot.img}}" class="tnx-linked-btn__icon"/>
                                                <span class="tnx-linked-btn__label">{{slot.name}}</span>
                                            </button>
                                        {{/if}}
                                        <div class="style-role-toggle {{#if slot.isEmpty}}style-role-toggle--disabled{{/if}}" {{#unless slot.isEmpty}}data-action="toggleStyleRole"{{/unless}}>
                                            <span class="role-indicator {{slot.roleIndicatorClass}}">{{slot.roleIndicatorDisplay}}</span>
                                        </div>
                                    </div>
                                </div>
                            {{/each}}
                        </div>
                        <div class="item-slots-row">
                            {{#each miracleSlots as |slot|}}
                                <div class="miracle-slot" data-item-id="{{slot._id}}">
                                {{#if slot.isEmpty}}
                                    <div class="tnx-import-box tnx-import-box--inline" data-drop-area="miracle"><span>神業をここにドロップ</span></div>
                                {{else}}
                                    <button type="button" class="item-button tnx-linked-btn" data-action="openItemSheet" data-item-id="{{slot._id}}" data-context-menu="item-edit">
                                        <img src="{{slot.img}}" class="tnx-linked-btn__icon"/>{{slot.name}}
                                    </button>
                                {{/if}}
                                </div>
                            {{/each}}
                        </div>
                    </div>
                    {{else}}
                    <div class="view-mode-miracle-actions">
                        <h3 class="tnx-section-title tnx-section-title--center">神業</h3>
                        <div class="miracle-buttons-grid">
                            {{#each miracleSlotsForView as |dw|}}
                                <button type="button" class="tnx-linked-btn miracle-use-button" data-action="useMiracle" data-item-id="{{dw._id}}" {{#if dw.isPlaceholder}}disabled{{/if}} {{#if dw.isDisabled}}disabled{{/if}} data-context-menu="miracle-view">
                                    <i class="fas fa-bolt"></i>
                                    <span class="tnx-linked-btn__label miracle-name__label">{{dw.name}}</span>
                                </button>
                            {{/each}}
                        </div>
                    </div>
                    {{/if}}
                </div>
            </div>
        </header>
     
        <section class="tabbed-content">
            <nav class="sheet-tabs tabs tnx-tabs" data-group="primary">
                <a class="item" data-action="tab" data-tab="abilities" data-group="primary">能力</a>
                <a class="item" data-action="tab" data-tab="check"     data-group="primary">判定</a>
                <a class="item" data-action="tab" data-tab="outfits"   data-group="primary">アウトフィット</a>
                <a class="item" data-action="tab" data-tab="status"    data-group="primary">状態</a>
                <a class="item" data-action="tab" data-tab="history"   data-group="primary">セッション履歴</a>
                <a class="item" data-action="tab" data-tab="profile"   data-group="primary">詳細</a>
            </nav>
            <section class="sheet-body tnx-body">
                <div class="tab abilities" data-group="primary" data-tab="abilities">
                    {{#if isEditMode}}
                        <h2 class="tnx-section-title">能力値管理</h2>
                        <div class="abilities-grid edit-mode-layout">
                            {{#each system.abilities as |ability key|}}
                                <div class="ability-block">
                                    <h3>{{ability.label}}</h3>
                                    <div class="value-control-wrapper">
                                        <input type="number" value="{{ability.totalValue}}" class="ability-value" disabled title="能力値">
                                        <span class="separator">/</span>
                                        <input type="number" value="{{ability.totalControl}}" class="control-value" disabled title="制御値">
                                    </div>
                                    <div class="ability-details-toggle" data-action="toggleAbilityDetails">
                                        <span>内訳</span>
                                        <i class="fas fa-chevron-down"></i>
                                    </div>
                                    <div class="ability-details-panel" style="display: none;">
                                        <div class="ability-breakdown breakdown-row">
                                            {{#each ability.styleContributions as |style|}}
                                                {{#if style.name}}
                                                    <label class="breakdown-label breakdown-label--style">{{style.name}} (SL{{style.level}})</label>
                                                    <div class="breakdown-item">
                                                        <input class="" type="number" value="{{style.value}}" disabled>
                                                        <span class="separator">/</span>
                                                        <input type="number" value="{{style.control}}" disabled>
                                                    </div>
                                                {{/if}}
                                            {{/each}}
                                            <label class="breakdown-label">効果</label>
                                            <div class="breakdown-item">
                                                <input type="number" name="system.{{key}}.effectMod" value="{{ability.effectMod}}" disabled>
                                                <span class="separator">/</span>
                                                <input type="number" name="system.{{key}}.controlEffectMod" value="{{ability.controlEffectMod}}" disabled>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="ability-main-inputs">
                                        <label>成長</label>
                                        <div class="input-row">
                                            <input type="number" name="system.{{key}}.growth" value="{{ability.growth}}">
                                            <span class="separator">/</span>
                                            <input type="number" name="system.{{key}}.controlGrowth" value="{{ability.controlGrowth}}">
                                        </div>
                                        <label>修正</label>
                                        <div class="input-row">
                                            <input type="number" name="system.{{key}}.mod" value="{{ability.mod}}">
                                            <span class="separator">/</span>
                                            <input type="number" name="system.{{key}}.controlMod" value="{{ability.controlMod}}">
                                        </div>
                                    </div>
                                </div>
                            {{/each}}
                        </div>
                    {{else}}
                        <h2 class="tnx-section-title">能力値</h2>
                        <div class="abilities-grid view-mode-layout">
                            {{#each system.abilities as |ability key|}}
                                <div class="ability-display">
                                    <div class="ability-label-shape"><div class="ability-label-content"><h3>{{ability.label}}</h3></div></div>
                                    <div class="ability-values-area">
                                        <div class="ability-value-shape">
                                            <div class="ability-value-content">
                                                <input type="number" value="{{ability.totalValue}}" readonly>
                                            </div>
                                        </div>
                                        <div class="control-value-shape">
                                            <div class="control-value-content">
                                                <input type="number" value="{{ability.totalControl}}" readonly>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {{/each}}
                        </div>
                    {{/if}}
                    <div class="skills-section">
                        {{#if isEditMode}}
                            {{!-- 編集モード：一般技能（閲覧モード踏襲の二列レイアウト） --}}
                            <div class="tnx-section-header">
                                <h3>一般技能</h3>
                                <a class="item-control item-create" data-type="generalSkill" title="追加">
                                    <i class="fas fa-plus"></i> 追加
                                </a>
                            </div>
                            <div class="skills-list-view">
                                {{#each generalSkillColumns as |columnItems|}}
                                    <div class="skills-column">
                                        {{#each columnItems as |item|}}
                                            <div class="general-skill-display general-skill-display--edit item" data-item-id="{{item._id}}">
                                                <div class="skill-name-wrap">
                                                    <a class="skill-name-plain squeeze-text">
                                                        {{tnxDecoratedName item}}
                                                    </a>
                                                </div>
                                                <div class="skill-meta-data">
                                                    <div class="skill-level-container">
                                                        <input type="number" class="skill-property-change" data-target="level" value="{{item.system.level}}" placeholder="Lv" />
                                                        <div class="skill-suits-row">
                                                            {{#each ../../TNX.SUITS as |suitData key|}}
                                                                <label class="suit-checkbox-tiny" title="{{suitData.label}}">
                                                                    <input type="checkbox" class="skill-property-change" data-target="suit" data-suit="{{key}}" {{checked (lookup item.system.suits key)}} />
                                                                    <i class="{{suitData.icon}}"></i>
                                                                </label>
                                                            {{/each}}
                                                        </div>
                                                    </div>
                                                </div>
                                                <a class="item-menu-trigger" title="メニュー">
                                                    <i class="fas fa-ellipsis-v"></i>
                                                </a>
                                            </div>
                                        {{/each}}
                                    </div>
                                {{/each}}
                            </div>

                            {{!-- 編集モード：スタイル技能（閲覧モード踏襲のグリッド） --}}
                            <div class="skills-section">
                                <div class="tnx-section-header">
                                    <h3>スタイル技能</h3>
                                    <a class="item-control item-create" data-type="styleSkill" title="追加">
                                        <i class="fas fa-plus"></i> 追加
                                    </a>
                                </div>
                                <div class="style-skills-list-wrapper">
                                    <div class="style-skill-header style-skill-grid style-skill-grid--edit">
                                        <div class="cell cell-name">名称</div>
                                        <div class="cell cell-level">Lv</div>
                                        <div class="cell cell-combo">技能</div>
                                        <div class="cell cell-max">上限</div>
                                        <div class="cell cell-timing">タイミング</div>
                                        <div class="cell cell-target">対象</div>
                                        <div class="cell cell-range">射程</div>
                                        <div class="cell cell-tn">目標値</div>
                                        <div class="cell cell-confront">対決</div>
                                        <div class="cell cell-other"></div>
                                    </div>
                                    <ol class="style-skills-list">
                                        {{#each styleSkills as |item|}}
                                            <li class="item style-skill-row style-skill-grid style-skill-grid--edit" data-item-id="{{item._id}}">
                                                <div class="cell cell-name">
                                                    <a class="item-name">{{tnxDecoratedName item}}</a>
                                                </div>
                                                <div class="cell cell-level">
                                                    <div class="skill-level-container">
                                                        <input type="number" class="skill-property-change" data-target="level" value="{{item.system.level}}" placeholder="Lv" />
                                                        <div class="skill-suits-row">
                                                            {{#each ../TNX.SUITS as |suitData key|}}
                                                                <label class="suit-checkbox-tiny" title="{{suitData.label}}">
                                                                    <input type="checkbox" class="skill-property-change" data-target="suit" data-suit="{{key}}" {{checked (lookup item.system.suits key)}} />
                                                                    <i class="{{suitData.icon}}"></i>
                                                                </label>
                                                            {{/each}}
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="cell cell-combo">
                                                    <span class="squeeze-text">{{item.view.comboSkill}}</span>
                                                </div>
                                                <div class="cell cell-max">
                                                    <span class="squeeze-text">{{item.view.maxLevel}}</span>
                                                </div>
                                                <div class="cell cell-timing">
                                                    <span class="squeeze-text">{{item.view.timing}}</span>
                                                </div>
                                                <div class="cell cell-target">
                                                    <span class="squeeze-text">{{item.view.target}}</span>
                                                </div>
                                                <div class="cell cell-range">
                                                    <span class="squeeze-text">{{item.view.range}}</span>
                                                </div>
                                                <div class="cell cell-tn">
                                                    <span class="squeeze-text">{{item.view.targetValue}}</span>
                                                </div>
                                                <div class="cell cell-confront">
                                                    <span class="squeeze-text">{{item.view.confrontation}}</span>
                                                </div>
                                                <div class="cell cell-other">
                                                    <a class="item-menu-trigger" title="メニュー">
                                                        <i class="fas fa-ellipsis-v"></i>
                                                    </a>
                                                </div>
                                            </li>
                                        {{/each}}
                                    </ol>
                                </div>
                            </div>
                        {{else}}
                            {{!-- 閲覧モード --}}
                            <div class="skills-section">
                                <h2 class="tnx-section-title">一般技能</h2>
                                <div class="skills-list-view">
                                    {{#each generalSkillColumns as |columnItems|}}
                                        <div class="skills-column">
                                            {{#each columnItems as |item|}}
                                                <div class="general-skill-display item" data-item-id="{{item._id}}">
                                                    <div class="skill-label-shape">
                                                        <a class="skill-label-content squeeze-text">
                                                            {{tnxDecoratedName item}}
                                                        </a>
                                                    </div>
                                                    <div class="skill-meta-data">
                                                        <span class="skill-level">Lv{{item.system.level}}</span>
                                                        <div class="skill-suits-view">
                                                            <i class="fas fa-spade suit-icon {{#if item.system.suits.spade}}active{{else}}inactive{{/if}}"></i>
                                                            <i class="fas fa-club suit-icon {{#if item.system.suits.club}}active{{else}}inactive{{/if}}"></i>
                                                            <i class="fas fa-heart suit-icon {{#if item.system.suits.heart}}active{{else}}inactive{{/if}}"></i>
                                                            <i class="fas fa-diamond suit-icon {{#if item.system.suits.diamond}}active{{else}}inactive{{/if}}"></i>
                                                        </div>
                                                    </div>
                                                    <a class="item-menu-trigger" title="メニュー">
                                                        <i class="fas fa-ellipsis-v"></i>
                                                    </a>
                                                </div>
                                            {{/each}}
                                        </div>
                                    {{/each}}
                                </div>
                            </div>
                            <div class="skills-section">
                                <h2 class="tnx-section-title">スタイル技能</h2>
                                <div class="style-skills-list-wrapper">
                                    {{!-- ヘッダー行 --}}
                                    <div class="style-skill-header style-skill-grid">
                                        <div class="cell cell-name">名称</div>
                                        <div class="cell cell-level">Lv</div>
                                        <div class="cell cell-combo">技能</div>
                                        <div class="cell cell-max">上限</div>
                                        <div class="cell cell-timing">タイミング</div>
                                        <div class="cell cell-target">対象</div>
                                        <div class="cell cell-range">射程</div>
                                        <div class="cell cell-tn">目標値</div>
                                        <div class="cell cell-confront">対決</div>
                                        <div class="cell cell-other"></div>
                                    </div>

                                    {{!-- リスト本体 --}}
                                    <ol class="style-skills-list">
                                        {{#each styleSkills as |item|}}
                                            <li class="item style-skill-row style-skill-grid" data-item-id="{{item._id}}">
                                                {{!-- 名称 --}}
                                                <div class="cell cell-name">
                                                    <a class="item-name">{{tnxDecoratedName item}}</a>
                                                </div>

                                                {{!-- レベル＆スート（横並びコンテナ） --}}
                                                <div class="cell cell-level">
                                                    <div class="level-container">
                                                        <span class="level-number">{{item.system.level}}</span>
                                                        <div class="level-suits">
                                                            <i class="fas fa-spade suit-icon {{#if item.system.suits.spade}}active{{else}}inactive{{/if}}"></i>
                                                            <i class="fas fa-club suit-icon {{#if item.system.suits.club}}active{{else}}inactive{{/if}}"></i>
                                                            <i class="fas fa-heart suit-icon {{#if item.system.suits.heart}}active{{else}}inactive{{/if}}"></i>
                                                            <i class="fas fa-diamond suit-icon {{#if item.system.suits.diamond}}active{{else}}inactive{{/if}}"></i>
                                                        </div>
                                                    </div>
                                                </div>

                                                {{!-- その他パラメータ --}}
                                                <div class="cell cell-combo">
                                                    <span class="squeeze-text">{{item.view.comboSkill}}</span>
                                                </div>
                                                <div class="cell cell-max">
                                                    <span class="squeeze-text">{{item.view.maxLevel}}</span>
                                                </div>
                                                <div class="cell cell-timing">
                                                    <span class="squeeze-text">{{item.view.timing}}</span>
                                                </div>
                                                <div class="cell cell-target">
                                                    <span class="squeeze-text">{{item.view.target}}</span>
                                                </div>
                                                <div class="cell cell-range">
                                                    <span class="squeeze-text">{{item.view.range}}</span>
                                                </div>
                                                <div class="cell cell-tn">
                                                    <span class="squeeze-text">{{item.view.targetValue}}</span>
                                                </div>
                                                <div class="cell cell-confront">
                                                    <span class="squeeze-text">{{item.view.confrontation}}</span>
                                                </div>
                                                <div class="cell cell-other">
                                                    <a class="item-menu-trigger" data-item-id="{{item._id}}" title="メニュー">
                                                        <i class="fas fa-ellipsis-v"></i>
                                                    </a>
                                                </div>
                                            </li>
                                        {{/each}}
                                    </ol>
                                </div>
                            </div>
                        {{/if}}
                    </div>
                </div>

                <div class="tab check" data-group="primary" data-tab="check"></div>

                <div class="tab outfits" data-group="primary" data-tab="outfits">
                    {{!-- 編集モード --}}
                    {{#if isEditMode}}
                        <div class="outfit-groups-container">
                            {{#each outfitGroups as |group|}}
                                <div class="tnx-item-list__row tnx-item-list__row--header skill-group-header">
                                    <h4 class="skill-name-header">{{group.label}}</h4>
                                    <a class="item-control item-create" data-type="outfit" data-major="{{group.key}}" title="追加">
                                        <i class="fas fa-plus"></i> 追加
                                    </a>
                                </div>

                                <div class="skill-group-block">
                                    {{#if group.hasItems}}
                                    <ol class="item-list">
                                        {{!-- ヘッダー行 (必要に応じて表示) --}}
                                        <li class="item-list-header-row flexrow">
                                            <div class="item-name">名前</div>
                                            <div class="item-prop">常備化</div>
                                            <div class="item-prop">部位</div>
                                            {{#if (eq group.key "weapon")}}<div class="item-prop">攻撃</div>{{/if}}
                                            {{#if (eq group.key "armor")}}<div class="item-prop">防御</div>{{/if}}
                                            <div class="item-controls"></div>
                                        </li>

                                        {{#each group.items as |item|}}
                                        <li class="item flexrow" data-item-id="{{item._id}}">
                                            <div class="item-name">
                                                <a class="item-edit">{{tnxDecoratedName item}}</a>
                                            </div>

                                            {{!-- 簡易ステータス表示 --}}
                                            <div class="item-prop">{{item.system.stock}}</div>
                                            <div class="item-prop">{{tnxPartLabel item.system.part}}</div>
                                            
                                            {{!-- 武器なら攻撃力 --}}
                                            {{#if (eq ../group.key "weapon")}}
                                                <div class="item-prop">{{item.system.attack.value}} / {{item.system.guardValue}}</div>
                                            {{/if}}
                                            
                                            {{!-- 防具なら防御力 --}}
                                            {{#if (eq ../group.key "armor")}}
                                                <div class="item-prop">{{item.system.defence.S_defence}}/{{item.system.defence.P_defence}}/{{item.system.defence.I_defence}}</div>
                                            {{/if}}

                                            <div class="item-controls">
                                                <a class="item-control item-edit" data-item-id="{{item._id}}" title="編集"><i class="fas fa-edit"></i></a>
                                                <a class="item-control item-delete" title="削除"><i class="fas fa-trash"></i></a>
                                            </div>
                                        </li>
                                        {{/each}}
                                    </ol>
                                    {{else}}
                                        <p class="no-items-message">アイテムがありません</p>
                                    {{/if}}
                                </div>
                            {{/each}}
                        </div>
                    
                    {{!-- 閲覧モード --}}
                    {{else}}
                        <div class="outfit-view-mode">
                            {{#each outfitGroups as |group|}}
                                {{#if group.hasItems}}
                                <div class="outfit-group-view">
                                    <h3>{{group.label}}</h3>
                                    <table class="tnx-table">
                                        <thead>
                                            <tr>
                                                <th>名称</th>
                                                <th>部位</th>
                                                {{#if (eq group.key "weapon")}}<th>攻撃/受</th><th>射程</th>{{/if}}
                                                {{#if (eq group.key "armor")}}<th>防御(S/P/I)</th><th>修正</th>{{/if}}
                                                {{#if (eq group.key "vehicle")}}<th>SF/乗員</th>{{/if}}
                                                <th>効果・解説</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {{#each group.items as |item|}}
                                            <tr class="item" data-item-id="{{item._id}}">
                                                <td class="item-name cell-clickable" data-action="rollStyleDescription">{{tnxDecoratedName item}}</td>
                                                <td>{{tnxPartLabel item.system.part}}</td>
                                                
                                                {{#if (eq ../group.key "weapon")}}
                                                    <td>{{item.system.attack.value}} / {{item.system.guardValue}}</td>
                                                    <td>{{tnxRangeLabel item.system.range}}</td>
                                                {{/if}}
                                                
                                                {{#if (eq ../group.key "armor")}}
                                                    <td>{{item.system.defence.S_defence}}/{{item.system.defence.P_defence}}/{{item.system.defence.I_defence}}</td>
                                                    <td>{{item.system.controlMod}}</td>
                                                {{/if}}
                                                
                                                {{#if (eq ../group.key "vehicle")}}
                                                    <td>{{item.system.speedFactor}} / {{item.system.passenger}}</td>
                                                {{/if}}

                                                <td class="cell-description squeeze-text">{{{item.system.description}}}</td>
                                            </tr>
                                            {{/each}}
                                        </tbody>
                                    </table>
                                </div>
                                {{/if}}
                            {{/each}}
                        </div>
                    {{/if}}
                </div>

                <div class="tab status" data-group="primary" data-tab="status">
                    {{> "systems/tokyo-nova-axleration/templates/parts/active-effects-list.hbs"}}
                    {{> "systems/tokyo-nova-axleration/templates/parts/bad-status-list.hbs"}}
                </div>

                <div class="tab history" data-group="primary" data-tab="history">
                    {{#if isEditMode}}
                    <div class="checkbox-row">
                        <label>
                            <input type="checkbox" name="system.syncWithOwner"
                                {{checked system.syncWithOwner}}>
                            レコードシートと同期
                        </label>
                    </div>
                    {{/if}}
                    {{> "systems/tokyo-nova-axleration/templates/parts/history-list.hbs"}}
                </div>

                <div class="tab profile" data-group="primary" data-tab="profile">
                    <section class="profile-lifepath-section">
                        <h3 class="tnx-section-title tnx-section-title--sm">ライフパス</h3>
                        <div class="lifepath-slots">
                            {{#each lifepathSlots as |slot|}}
                            <div class="lifepath-slot-row">
                                <span class="lifepath-type-label">{{slot.label}}</span>
                                {{#if ../isEditMode}}
                                    {{#if slot.hasItem}}
                                        <button type="button" class="item-button tnx-linked-btn lifepath-item-btn" data-action="openLifepathItem" data-lifepath-key="{{slot.key}}">
                                            <span class="tnx-linked-btn__label">{{slot.name}}</span>
                                        </button>
                                        <a class="item-control lifepath-delete-btn" data-action="removeLifepath" data-lifepath-key="{{slot.key}}" title="削除">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    {{else}}
                                        <div class="tnx-import-box tnx-import-box--inline lifepath-import-box" data-drop-area="lifepath-{{slot.key}}">
                                            <span>ライフパスをドロップ</span>
                                        </div>
                                    {{/if}}
                                {{else}}
                                    <span class="lifepath-name">{{#if slot.name}}{{slot.name}}{{else}}—{{/if}}</span>
                                    {{#if slot.summary}}<span class="lifepath-summary">{{slot.summary}}</span>{{/if}}
                                {{/if}}
                            </div>
                            {{/each}}
                        </div>
                    </section>

                    <div class="tnx-editor-section">
                        <div class="tnx-editor-section__header">
                            <label>キャラクター説明</label>
                            <i class="fa-solid fa-pen-to-square tnx-editor-mode-icon"></i>
                        </div>
                        <div class="tnx-editor-section__content">
                            {{#if isEditMode}}
                                {{editor enrichedDescription target="system.description" engine="prosemirror" button=false owner=owner editable=editable}}
                            {{else}}
                                <div class="tnx-editor-view-content">{{{enrichedDescription}}}</div>
                            {{/if}}
                        </div>
                    </div>
                </div>

            </section>
        </section>
    </section>
</section>