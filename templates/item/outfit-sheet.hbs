<section class="{{cssClass}}">
    {{!-- ヘッダーエリア --}}
    <header class="sheet-header outfit-header">
        <img class="profile-img" src="{{item.img}}" data-edit="img" data-action="editImage" title="{{item.name}}"/>
        <div class="header-fields">
            <div class="charname-row">
                <h1 class="charname">
                    {{#if isEditMode}}
                        <input name="name" type="text" value="{{item.name}}" placeholder="アウトフィット名"/>
                    {{else}}
                        <span class="charname-view">{{tnxDecoratedName item}}</span>
                    {{/if}}
                </h1>
                {{#if system.isConsumption}}
                    <div class="outfit-quantity" title="個数">
                        <span class="outfit-quantity__times">×</span>
                        {{#if isEditMode}}
                            <input type="number" name="system.quantity.value" value="{{system.quantity.value}}" min="0">
                        {{else}}
                            <span class="outfit-quantity__value">{{system.quantity.value}}</span>
                        {{/if}}
                    </div>
                {{/if}}
            </div>
            <div class="outfit-category">
                {{#if isEditMode}}
                    <select name="system.majorCategory">
                        {{selectOptions options.majorCategory selected=system.majorCategory}}
                    </select>
                    <select name="system.minorCategory">
                        {{selectOptions options.minorCategory selected=system.minorCategory}}
                    </select>
                {{else}}
                    <span class="outfit-category-label">{{view.category}}</span>
                {{/if}}
            </div>
        </div>
    </header>

    {{!-- タブナビゲーション --}}
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-action="tab" data-group="primary" data-tab="description">説明</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="setting">設定</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="usage">用途</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="effects">エフェクト</a>
    </nav>

    {{!-- タブコンテンツ --}}
    <section class="sheet-body">

        {{!-- 説明タブ --}}
        <div class="tab description" data-group="primary" data-tab="description">
            <div class="style-skill-display">
                <div class="style-skill-display-grid">
                    {{#each view.summary as |row|}}
                        <div>
                            <label>{{row.label}}：</label>
                            <span>{{row.value}}</span>
                        </div>
                    {{/each}}
                </div>
            </div>

            <div class="tnx-editor-section">
                <div class="tnx-editor-section__header">
                    <label>解説</label>
                </div>
                <div class="tnx-editor-section__content">
                    {{editor enrichedDescription target="system.description" engine="prosemirror" button=true owner=owner editable=editable}}
                </div>
            </div>
        </div>

        {{!-- 設定タブ --}}
        <div class="tab setting" data-group="primary" data-tab="setting">
            <div class="settings-grid">
                <fieldset class="tnx-fieldset">
                    <legend>識別キー</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>識別キー</label>
                            <input type="text" name="system.identificationKey" value="{{system.identificationKey}}" placeholder="識別キーを入力"/>
                        </div>
                    </div>
                </fieldset>

                {{#if (or isArmor isCyborg)}}
                <fieldset class="tnx-fieldset">
                    <legend>防御データ</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>防御値(S)</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.defence.S_defence">-</button>
                                <input type="number" name="system.defence.S_defence" value="{{system.defence.S_defence}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.defence.S_defence">+</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>防御値(P)</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.defence.P_defence">-</button>
                                <input type="number" name="system.defence.P_defence" value="{{system.defence.P_defence}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.defence.P_defence">+</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>防御値(I)</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.defence.I_defence">-</button>
                                <input type="number" name="system.defence.I_defence" value="{{system.defence.I_defence}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.defence.I_defence">+</button>
                            </div>
                        </div>
                        {{#if isArmor}}
                            <div class="form-group">
                                <label>制御値修正</label>
                                <div class="number-input-spinner skill-sheet-spinner">
                                    <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.controlMod">-</button>
                                    <input type="number" name="system.controlMod" value="{{system.controlMod}}">
                                    <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.controlMod">+</button>
                                </div>
                            </div>
                        {{/if}}
                    </div>
                </fieldset>
                {{/if}}

                {{#if (or isWeapon isCyborg)}}
                <fieldset class="tnx-fieldset">
                    <legend>攻撃データ</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>攻撃力</label>
                            <div class="form-fields split-fields">
                                <select name="system.attack.damageType">
                                    {{selectOptions options.damageType selected=system.attack.damageType}}
                                </select>
                                <div class="number-input-spinner skill-sheet-spinner">
                                    <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.attack.value">-</button>
                                    <input type="number" name="system.attack.value" value="{{system.attack.value}}">
                                    <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.attack.value">+</button>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>攻撃修正</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.attack.mod">-</button>
                                <input type="number" name="system.attack.mod" value="{{system.attack.mod}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.attack.mod">+</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>受け値</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.guardValue">-</button>
                                <input type="number" name="system.guardValue" value="{{system.guardValue}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.guardValue">+</button>
                            </div>
                        </div>
                        {{#if isWeapon}}
                            <div class="form-group">
                                <label>射程</label>
                                <div class="form-fields split-fields">
                                    <select name="system.range.min">
                                        {{selectOptions options.weaponRange selected=system.range.min}}
                                    </select>
                                    <span class="range-separator">～</span>
                                    <select name="system.range.max">
                                        {{selectOptions options.weaponRange selected=system.range.max}}
                                    </select>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>攻撃範囲</label>
                                <select name="system.attackArea">
                                    {{selectOptions options.attackArea selected=system.attackArea}}
                                </select>
                            </div>
                            <div class="form-group">
                                <label>レーザー兵器</label>
                                <input type="checkbox" name="system.isLaser" {{checked system.isLaser}}>
                            </div>
                            <div class="form-group">
                                <label>フルオート</label>
                                <input type="checkbox" name="system.isFullAuto" {{checked system.isFullAuto}}>
                            </div>
                            {{#if system.isFullAuto}}
                                <div class="form-group">
                                    <label>FA値</label>
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.FAValue" data-min="0">-</button>
                                        <input type="number" name="system.FAValue" value="{{system.FAValue}}" min="0">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.FAValue">+</button>
                                    </div>
                                </div>
                            {{/if}}
                        {{/if}}
                    </div>
                </fieldset>
                {{/if}}

                {{#if hasSlots}}
                <fieldset class="tnx-fieldset">
                    <legend>スロット</legend>
                    <div class="tnx-form-field">
                        {{#each system.slots as |pool|}}
                            <div class="form-group">
                                <label>{{lookup ../options.slotKinds pool.kind}}</label>
                                <div class="number-input-spinner skill-sheet-spinner">
                                    <button type="button" class="tnx-btn" data-action="decrementSlot" data-kind="{{pool.kind}}">-</button>
                                    <input type="number" value="{{pool.count}}" min="0" data-slot-kind="{{pool.kind}}">
                                    <button type="button" class="tnx-btn" data-action="incrementSlot" data-kind="{{pool.kind}}">+</button>
                                </div>
                            </div>
                        {{/each}}
                    </div>
                </fieldset>
                {{/if}}

                <fieldset class="tnx-fieldset">
                    <legend>アウトフィット 詳細設定</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>購入値</label>
                            <div class="form-fields {{#if (eq system.buy.mode "value")}}split-fields{{/if}}">
                                <select name="system.buy.mode">
                                    {{selectOptions options.buyHideMode selected=system.buy.mode}}
                                </select>
                                {{#if (eq system.buy.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.buy.value">-</button>
                                        <input type="number" name="system.buy.value" value="{{system.buy.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.buy.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>

                        <div class="form-group">
                            <label>常備化経験点</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.preserveExp">-</button>
                                <input type="number" name="system.preserveExp" value="{{system.preserveExp}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.preserveExp">+</button>
                            </div>
                        </div>

                        {{#if system.isConsumption}}
                            <div class="form-group">
                                <label>常備化個数</label>
                                <div class="number-input-spinner skill-sheet-spinner">
                                    <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.quantity.max" data-min="0">-</button>
                                    <input type="number" name="system.quantity.max" value="{{system.quantity.max}}" min="0">
                                    <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.quantity.max">+</button>
                                </div>
                            </div>
                        {{/if}}

                        <div class="form-group">
                            <label>隠匿値</label>
                            <div class="form-fields {{#if (eq system.hide.mode "value")}}split-fields{{/if}}">
                                <select name="system.hide.mode">
                                    {{selectOptions options.buyHideMode selected=system.hide.mode}}
                                </select>
                                {{#if (eq system.hide.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.hide.value">-</button>
                                        <input type="number" name="system.hide.value" value="{{system.hide.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.hide.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>

                        <div class="form-group">
                            <label>危険値</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.appearancePenalty">-</button>
                                <input type="number" name="system.appearancePenalty" value="{{system.appearancePenalty}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.appearancePenalty">+</button>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>電脳制御値</label>
                            <div class="form-fields {{#if (eq system.hack.mode "value")}}split-fields{{/if}}">
                                <select name="system.hack.mode">
                                    {{selectOptions options.hackMode selected=system.hack.mode}}
                                </select>
                                {{#if (eq system.hack.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.hack.value">-</button>
                                        <input type="number" name="system.hack.value" value="{{system.hack.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.hack.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>

                        <div class="form-group">
                            <label>部位</label>
                            <div class="form-fields split-fields">
                                <input type="text" name="system.part.value" value="{{system.part.value}}" placeholder="部位を入力"/>
                                <div class="number-input-spinner skill-sheet-spinner">
                                    <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.part.slots" data-min="0">-</button>
                                    <input type="number" name="system.part.slots" value="{{system.part.slots}}" min="0">
                                    <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.part.slots">+</button>
                                </div>
                            </div>
                        </div>

                        {{!-- タイミング(スタイル技能と共通の選択肢) --}}
                        <div class="form-group align-start">
                            <label>タイミング</label>
                            <div class="form-fields-column">
                                {{#each system.timing as |t idx|}}
                                <div class="array-row">
                                    <select name="system.timing.{{idx}}.value">
                                        {{selectOptions ../options.timing selected=t.value}}
                                    </select>

                                    {{#if (eq t.value "other")}}
                                        <input type="text" name="system.timing.{{idx}}.timingOther" value="{{t.timingOther}}" placeholder="タイミングを入力"/>
                                    {{/if}}
                                    {{#if (eq t.value "action")}}
                                        <select name="system.timing.{{idx}}.actionName">
                                            {{selectOptions ../options.actions selected=t.actionName}}
                                        </select>
                                    {{/if}}
                                    {{#if (eq t.value "process")}}
                                        <select name="system.timing.{{idx}}.processName">
                                            {{selectOptions ../options.processes selected=t.processName}}
                                        </select>
                                    {{/if}}

                                    <div class="row-controls">
                                        {{#if (eq idx 0)}}
                                            <a class="tnx-row-btn" data-target="timing" title="行を追加">
                                                <i class="fas fa-plus"></i>
                                            </a>
                                        {{/if}}
                                        {{#if (gte idx 1)}}
                                            <a class="tnx-row-btn--delete" data-target="timing" data-index="{{idx}}" title="削除">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        {{/if}}
                                    </div>
                                </div>
                                {{/each}}
                            </div>
                        </div>

                        <div class="form-group">
                            <label>専用</label>
                            <input type="text" name="system.exclusive" value="{{system.exclusive}}" placeholder="専用スタイル・ワークス"/>
                        </div>

                        {{!-- 使用回数(スタイル技能と同形。数値入力はスピナー不使用の例外) --}}
                        <div class="form-group">
                            <label for="isLimit-{{item._id}}">使用回数に制限あり</label>
                            <input type="checkbox" name="system.uses.isLimit" id="isLimit-{{item._id}}" {{checked system.uses.isLimit}}>
                        </div>
                        {{#if system.uses.isLimit}}
                            <div class="form-group">
                                <label>種別</label>
                                <select name="system.uses.type">
                                    {{selectOptions options.usesType selected=system.uses.type}}
                                </select>
                            </div>
                            <div class="form-group usage-limit-group">
                                <label>使用回数</label>
                                <div class="usage-inputs">
                                    <div class="usage-field">
                                        <label>現在値</label>
                                        <input type="number" name="system.uses.value" value="{{system.uses.value}}">
                                    </div>
                                    <span class="usage-separator">/</span>
                                    <div class="usage-field">
                                        <label>最大値</label>
                                        <input type="number" name="system.uses.max" value="{{system.uses.max}}">
                                    </div>
                                </div>
                            </div>
                        {{/if}}
                    </div>
                </fieldset>

                <fieldset class="tnx-fieldset">
                    <legend>状態・性質</legend>
                    <div class="outfit-flags">
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isPrepared" {{checked system.isPrepared}}>
                            <span>準備済み</span>
                        </label>
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isCarrying" {{checked system.isCarrying}}>
                            <span>携帯中</span>
                        </label>
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isCyber" {{checked system.isCyber}}>
                            <span>サイバーウェア</span>
                        </label>
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isBiological" {{checked system.isBiological}}>
                            <span>生体装備</span>
                        </label>
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isPre-play" {{checked (lookup system "isPre-play")}}>
                            <span>プリプレイ購入</span>
                        </label>
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isOption" {{checked system.isOption}}>
                            <span>オプション</span>
                        </label>
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isConsumption" {{checked system.isConsumption}}>
                            <span>消費アイテム</span>
                        </label>
                    </div>
                </fieldset>
            </div>
        </div>

        {{!-- 用途タブ --}}
        <div class="tab usage" data-group="primary" data-tab="usage">
            {{> "systems/tokyo-nova-axleration/templates/parts/usage-list.hbs"}}
        </div>

        {{!-- エフェクトタブ --}}
        <div class="tab effects" data-group="primary" data-tab="effects">
            {{> "systems/tokyo-nova-axleration/templates/parts/active-effects-list.hbs"}}
        </div>
    </section>
</section>
