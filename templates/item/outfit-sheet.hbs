<section class="{{cssClass}}">
    {{!-- ヘッダーエリア --}}
    <header class="sheet-header outfit-header">
        <img class="profile-img" src="{{item.img}}" data-edit="img" data-action="editImage" title="{{item.name}}"/>
        <div class="header-fields">
            <div class="charname-row">
                <h1 class="charname">
                    {{#if isEditMode}}
                        <input name="name" type="text" value="{{item.name}}" placeholder="アウトフィット名"/>
                    {{else}}
                        <span class="charname-view">{{tnxDecoratedName item}}</span>
                    {{/if}}
                </h1>
                {{#if system.isConsumption}}
                    <div class="outfit-quantity" title="個数">
                        <span class="outfit-quantity__times">×</span>
                        {{#if isEditMode}}
                            <input type="number" name="system.quantity.value" value="{{system.quantity.value}}" min="0">
                        {{else}}
                            <span class="outfit-quantity__value">{{system.quantity.value}}</span>
                        {{/if}}
                    </div>
                {{/if}}
            </div>
            <div class="outfit-category">
                {{#if isEditMode}}
                    {{#if isBothCategoryFixed}}
                        <span class="outfit-category-label">{{view.category}}</span>
                    {{else}}
                        {{#if isMajorCategoryFixed}}
                            <span class="outfit-category-label">{{fixedMajorLabel}}／</span>
                        {{else}}
                            <select name="system.majorCategory">
                                {{selectOptions options.majorCategory selected=system.majorCategory}}
                            </select>
                        {{/if}}
                        <select name="system.minorCategory">
                            {{selectOptions options.minorCategory selected=system.minorCategory}}
                        </select>
                    {{/if}}
                {{else}}
                    <span class="outfit-category-label">{{view.category}}</span>
                {{/if}}
                {{#if linkedArea}}
                    <span class="outfit-area-badge" title="住宅エリア"><i class="fa-solid fa-city"></i> {{linkedArea.name}}</span>
                {{/if}}
            </div>
        </div>
    </header>

    {{!-- タブナビゲーション --}}
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-action="tab" data-group="primary" data-tab="description">説明</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="setting">設定</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="usage">用途</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="effects">エフェクト</a>
    </nav>

    {{!-- タブコンテンツ --}}
    <section class="sheet-body">

        {{!-- 説明タブ --}}
        <div class="tab description" data-group="primary" data-tab="description">
            <div class="style-skill-display">
                <div class="style-skill-display-grid">
                    {{#each view.summary as |row|}}
                        <div>
                            <label>{{row.label}}：</label>
                            <span>{{row.value}}</span>
                        </div>
                    {{/each}}
                </div>
            </div>

            <div class="tnx-editor-section">
                <div class="tnx-editor-section__header">
                    <label>解説</label>
                </div>
                <div class="tnx-editor-section__content">
                    {{editor enrichedDescription target="system.description" engine="prosemirror" button=true owner=owner editable=editable}}
                </div>
            </div>
        </div>

        {{!-- 設定タブ --}}
        <div class="tab setting" data-group="primary" data-tab="setting">
            <div class="settings-grid">
                <fieldset class="tnx-fieldset">
                    <legend>識別キー</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>識別キー</label>
                            <input type="text" name="system.identificationKey" value="{{system.identificationKey}}" placeholder="識別キーを入力"/>
                        </div>
                    </div>
                </fieldset>

                {{#unless isCombiner}}
                <fieldset class="tnx-fieldset">
                    <legend>性質</legend>
                    <div class="outfit-flags">
                        {{#unless isCyberByCategory}}
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isCyber" {{checked system.isCyber}}>
                            <span>サイバーウェア</span>
                        </label>
                        {{/unless}}
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isOption" {{checked system.isOption}}>
                            <span>オプション</span>
                        </label>
                        <label class="outfit-flag">
                            <input type="checkbox" name="system.isConsumption" {{checked system.isConsumption}}>
                            <span>消費アイテム</span>
                        </label>
                    </div>
                    {{#if system.isOption}}
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>装備対象</label>
                            <select name="system.parentItemId">
                                {{selectOptions options.parentItem selected=system.parentItemId}}
                            </select>
                        </div>
                        {{#if system.parentItemId}}
                        {{#if parentHasSlots}}
                        <div class="form-group">
                            <label>装備スロット</label>
                            <select name="system.parentSlotKind">
                                {{selectOptions options.parentSlot selected=system.parentSlotKind}}
                            </select>
                        </div>
                        {{/if}}
                        {{/if}}
                    </div>
                    {{/if}}
                </fieldset>
                {{/unless}}

                {{#if hasDefence}}
                <fieldset class="tnx-fieldset">
                    <legend>防御データ</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>防御力</label>
                            <select name="system.defence.mode">
                                {{selectOptions options.noneValueMode selected=system.defence.mode}}
                            </select>
                        </div>
                        {{#if (eq system.defence.mode "value")}}
                        <div class="form-group">
                            <label>防御値(S)</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.defence.S_defence">-</button>
                                <input type="number" name="system.defence.S_defence" value="{{system.defence.S_defence}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.defence.S_defence">+</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>防御値(P)</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.defence.P_defence">-</button>
                                <input type="number" name="system.defence.P_defence" value="{{system.defence.P_defence}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.defence.P_defence">+</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>防御値(I)</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.defence.I_defence">-</button>
                                <input type="number" name="system.defence.I_defence" value="{{system.defence.I_defence}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.defence.I_defence">+</button>
                            </div>
                        </div>
                        {{/if}}
                        {{#if isArmor}}
                            <div class="form-group">
                                <label>制御値修正</label>
                                <div class="form-fields {{#if (eq system.controlMod.mode "value")}}split-fields{{/if}}">
                                    <select name="system.controlMod.mode">
                                        {{selectOptions options.noneValueMode selected=system.controlMod.mode}}
                                    </select>
                                    {{#if (eq system.controlMod.mode "value")}}
                                        <div class="number-input-spinner skill-sheet-spinner">
                                            <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.controlMod.value">-</button>
                                            <input type="number" name="system.controlMod.value" value="{{system.controlMod.value}}">
                                            <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.controlMod.value">+</button>
                                        </div>
                                    {{/if}}
                                </div>
                            </div>
                        {{/if}}
                    </div>
                </fieldset>
                {{/if}}

                {{#if hasAttack}}
                <fieldset class="tnx-fieldset">
                    <legend>攻撃データ</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>攻撃力</label>
                            <div class="form-fields split-fields">
                                <select name="system.attack.damageType">
                                    {{selectOptions options.damageType selected=system.attack.damageType}}
                                </select>
                                <div class="number-input-spinner skill-sheet-spinner">
                                    <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.attack.value">-</button>
                                    <input type="number" name="system.attack.value" value="{{system.attack.value}}">
                                    <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.attack.value">+</button>
                                </div>
                            </div>
                        </div>
                        {{!-- 攻撃修正(旧 attack.mod)は AE 着地点 attack.effectMod へ移行し UI から削除(フェーズ9-3) --}}
                        {{#if hasGuard}}
                        <div class="form-group">
                            <label>受け値</label>
                            <div class="form-fields {{#if (eq system.guardValue.mode "value")}}split-fields{{/if}}">
                                <select name="system.guardValue.mode">
                                    {{selectOptions options.noneValueMode selected=system.guardValue.mode}}
                                </select>
                                {{#if (eq system.guardValue.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.guardValue.value">-</button>
                                        <input type="number" name="system.guardValue.value" value="{{system.guardValue.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.guardValue.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                        {{/if}}
                        {{#if isWeapon}}
                            <div class="form-group">
                                <label>射程</label>
                                <div class="form-fields {{#unless (eq system.range.min "none")}}split-fields{{/unless}}">
                                    <select name="system.range.min">
                                        {{selectOptions options.weaponRangeMin selected=system.range.min}}
                                    </select>
                                    {{#unless (eq system.range.min "none")}}
                                        <span class="range-separator">～</span>
                                        <select name="system.range.max">
                                            {{selectOptions options.weaponRangeMax selected=system.range.max}}
                                        </select>
                                    {{/unless}}
                                </div>
                            </div>
                            <div class="form-group">
                                <label>攻撃範囲</label>
                                <select name="system.attackArea">
                                    {{selectOptions options.attackArea selected=system.attackArea}}
                                </select>
                            </div>
                            <div class="form-group">
                                <label>レーザー兵器</label>
                                <input type="checkbox" name="system.isLaser" {{checked system.isLaser}}>
                            </div>
                            <div class="form-group">
                                <label>フルオート</label>
                                <input type="checkbox" name="system.isFullAuto" {{checked system.isFullAuto}}>
                            </div>
                            {{#if system.isFullAuto}}
                                <div class="form-group">
                                    <label>FA値</label>
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.FAValue" data-min="0">-</button>
                                        <input type="number" name="system.FAValue" value="{{system.FAValue}}" min="0">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.FAValue">+</button>
                                    </div>
                                </div>
                            {{/if}}
                        {{/if}}
                    </div>
                </fieldset>
                {{/if}}

                {{#if isIanus}}
                <fieldset class="tnx-fieldset">
                    <legend>IANUSデータ</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>制御値修正</label>
                            <div class="form-fields {{#if (eq system.controlMod.mode "value")}}split-fields{{/if}}">
                                <select name="system.controlMod.mode">
                                    {{selectOptions options.noneValueMode selected=system.controlMod.mode}}
                                </select>
                                {{#if (eq system.controlMod.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.controlMod.value">-</button>
                                        <input type="number" name="system.controlMod.value" value="{{system.controlMod.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.controlMod.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </fieldset>
                {{/if}}

                {{#if isTap}}
                <fieldset class="tnx-fieldset">
                    <legend>タップデータ</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>サイクル数</label>
                            <div class="form-fields {{#if (eq system.cycle.mode "value")}}split-fields{{/if}}">
                                <select name="system.cycle.mode">
                                    {{selectOptions options.noneValueMode selected=system.cycle.mode}}
                                </select>
                                {{#if (eq system.cycle.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.cycle.value" data-min="0">-</button>
                                        <input type="number" name="system.cycle.value" value="{{system.cycle.value}}" min="0">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.cycle.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                        <div class="form-group">
                            <label>CS修正</label>
                            <div class="form-fields {{#if (eq system.combatSpeedMod.mode "value")}}split-fields{{/if}}">
                                <select name="system.combatSpeedMod.mode">
                                    {{selectOptions options.noneValueMode selected=system.combatSpeedMod.mode}}
                                </select>
                                {{#if (eq system.combatSpeedMod.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.combatSpeedMod.value">-</button>
                                        <input type="number" name="system.combatSpeedMod.value" value="{{system.combatSpeedMod.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.combatSpeedMod.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </fieldset>
                {{/if}}

                {{#if isVehicle}}
                <fieldset class="tnx-fieldset">
                    <legend>ヴィークルデータ</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>移動力(SF)</label>
                            <div class="form-fields {{#if (eq system.speedFactor.mode "value")}}split-fields{{/if}}">
                                <select name="system.speedFactor.mode">
                                    {{selectOptions options.noneValueMode selected=system.speedFactor.mode}}
                                </select>
                                {{#if (eq system.speedFactor.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.speedFactor.value" data-min="0">-</button>
                                        <input type="number" name="system.speedFactor.value" value="{{system.speedFactor.value}}" min="0">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.speedFactor.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                        <div class="form-group">
                            <label>乗員</label>
                            <div class="form-fields {{#if (eq system.passenger.mode "value")}}split-fields{{/if}}">
                                <select name="system.passenger.mode">
                                    {{selectOptions options.noneValueMode selected=system.passenger.mode}}
                                </select>
                                {{#if (eq system.passenger.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.passenger.value" data-min="0">-</button>
                                        <input type="number" name="system.passenger.value" value="{{system.passenger.value}}" min="0">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.passenger.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                        <div class="form-group">
                            <label>制御値修正</label>
                            <div class="form-fields {{#if (eq system.controlMod.mode "value")}}split-fields{{/if}}">
                                <select name="system.controlMod.mode">
                                    {{selectOptions options.noneValueMode selected=system.controlMod.mode}}
                                </select>
                                {{#if (eq system.controlMod.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.controlMod.value">-</button>
                                        <input type="number" name="system.controlMod.value" value="{{system.controlMod.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.controlMod.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </fieldset>
                {{/if}}

                {{#if isResidence}}
                <fieldset class="tnx-fieldset">
                    <legend>住宅エリア</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>エリアを選択</label>
                            <select name="system.housingArea" {{#if system.useHousingAreaDrop}}disabled{{/if}}>
                                {{selectOptions options.housingArea selected=system.housingArea blank="-"}}
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="useHousingAreaDrop-{{item._id}}">住宅エリアアイテムをドロップしてエリア設定</label>
                            <input type="checkbox" id="useHousingAreaDrop-{{item._id}}" name="system.useHousingAreaDrop" {{checked system.useHousingAreaDrop}}>
                        </div>
                        {{#if system.useHousingAreaDrop}}
                        <div class="form-group">
                            <label>エリア(ドロップ)</label>
                            <div class="housing-area-row">
                                {{#if linkedArea}}
                                    <button type="button" class="tnx-linked-btn housing-area-linked"
                                            data-action="viewHousingArea"
                                            data-context-menu="housing-area"
                                            {{#unless isEditMode}}disabled{{/unless}}>
                                        <img src="{{linkedArea.img}}" class="tnx-linked-btn__icon"/>
                                        <span class="tnx-linked-btn__label">{{linkedArea.name}}</span>
                                    </button>
                                    <button type="button" class="tnx-btn tnx-btn--sm" data-action="clearHousingArea">クリア</button>
                                {{else}}
                                    <div class="tnx-import-box tnx-import-box--dropzone" data-drop-area="housing-area">
                                        <span>住宅エリアアイテムをここにドロップ</span>
                                    </div>
                                    <button type="button" class="tnx-btn tnx-btn--sm" disabled>クリア</button>
                                {{/if}}
                            </div>
                        </div>
                        {{/if}}
                        {{#if linkedArea}}
                        <div class="form-group">
                            <label>エリアランク</label>
                            <span class="linked-value">{{linkedArea.rankLabel}}</span>
                        </div>
                        {{#each linkedArea.mods as |mod|}}
                        <div class="form-group">
                            <label>{{mod.label}} 修正</label>
                            <span class="linked-value">{{mod.value}}</span>
                        </div>
                        {{/each}}
                        {{/if}}
                    </div>
                </fieldset>

                <fieldset class="tnx-fieldset">
                    <legend>住宅施設データ</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>登場判定目標値</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.appearanceTarget">-</button>
                                <input type="number" name="system.appearanceTarget" value="{{system.appearanceTarget}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.appearanceTarget">+</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>電脳セキュリティ</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.cyberSecurity">-</button>
                                <input type="number" name="system.cyberSecurity" value="{{system.cyberSecurity}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.cyberSecurity">+</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>アナログセキュリティ</label>
                            <div class="number-input-spinner skill-sheet-spinner">
                                <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.analogSecurity">-</button>
                                <input type="number" name="system.analogSecurity" value="{{system.analogSecurity}}">
                                <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.analogSecurity">+</button>
                            </div>
                        </div>
                    </div>
                </fieldset>
                {{/if}}

                {{#if isCombiner}}
                <fieldset class="tnx-fieldset">
                    <legend>コンバイン</legend>
                    <div class="tnx-form-field">
                        {{!-- 元アイテム1: 設定済みは tnx-linked-btn + クリア、未設定はドロップゾーン + disabled クリア --}}
                        <div class="form-group">
                            <label>元アイテム1</label>
                            <div class="combine-source-row">
                                {{#if combine.source1}}
                                    <label class="combine-appearance-eye" title="見た目に設定">
                                        <input type="radio" name="system.combine.appearance" value="1" {{#if (eq combine.appearance "1")}}checked{{/if}} {{#unless isEditMode}}disabled{{/unless}}>
                                        <i class="fa-solid fa-eye"></i>
                                    </label>
                                    <button type="button" class="tnx-linked-btn combine-source-linked"
                                            data-action="viewCombineSource"
                                            data-source="1"
                                            data-context-menu="combine-source"
                                            {{#unless isEditMode}}disabled{{/unless}}>
                                        <img src="{{combine.source1.img}}" class="tnx-linked-btn__icon"/>
                                        <span class="tnx-linked-btn__label">{{combine.source1.name}}</span>
                                    </button>
                                    <button type="button" class="tnx-btn tnx-btn--sm" data-action="clearCombineSource" data-source="1">クリア</button>
                                {{else}}
                                    <span class="combine-appearance-eye combine-appearance-eye--empty" title="見た目（未設定）">
                                        <i class="fa-regular fa-eye-slash"></i>
                                    </span>
                                    <div class="tnx-import-box tnx-import-box--dropzone" data-drop-area="combine-1">
                                        <span>アウトフィットをここにドロップ</span>
                                    </div>
                                    <button type="button" class="tnx-btn tnx-btn--sm" disabled>クリア</button>
                                {{/if}}
                            </div>
                        </div>
                        {{!-- 元アイテム2: 設定済みは tnx-linked-btn + クリア、未設定はドロップゾーン + disabled クリア --}}
                        <div class="form-group">
                            <label>元アイテム2</label>
                            <div class="combine-source-row">
                                {{#if combine.source2}}
                                    <label class="combine-appearance-eye" title="見た目に設定">
                                        <input type="radio" name="system.combine.appearance" value="2" {{#if (eq combine.appearance "2")}}checked{{/if}} {{#unless isEditMode}}disabled{{/unless}}>
                                        <i class="fa-solid fa-eye"></i>
                                    </label>
                                    <button type="button" class="tnx-linked-btn combine-source-linked"
                                            data-action="viewCombineSource"
                                            data-source="2"
                                            data-context-menu="combine-source"
                                            {{#unless isEditMode}}disabled{{/unless}}>
                                        <img src="{{combine.source2.img}}" class="tnx-linked-btn__icon"/>
                                        <span class="tnx-linked-btn__label">{{combine.source2.name}}</span>
                                    </button>
                                    <button type="button" class="tnx-btn tnx-btn--sm" data-action="clearCombineSource" data-source="2">クリア</button>
                                {{else}}
                                    <span class="combine-appearance-eye combine-appearance-eye--empty" title="見た目（未設定）">
                                        <i class="fa-regular fa-eye-slash"></i>
                                    </span>
                                    <div class="tnx-import-box tnx-import-box--dropzone" data-drop-area="combine-2">
                                        <span>アウトフィットをここにドロップ</span>
                                    </div>
                                    <button type="button" class="tnx-btn tnx-btn--sm" disabled>クリア</button>
                                {{/if}}
                            </div>
                        </div>

                        {{!-- 食い違うパラメータを使用回数制限と同形式のラジオで選択 --}}
                        {{#if combine.paramRows}}
                        <div class="combine-param-section">
                            <div class="combine-param-section__title">パラメータ選択</div>
                            {{#each combine.paramRows as |row|}}
                            <div class="form-group usage-limit-group">
                                <label>{{row.label}}</label>
                                <div class="usage-inputs">
                                    <div class="usage-field">
                                        <label>元1（{{row.val1}}）</label>
                                        <input type="radio" name="system.combine.params.{{row.key}}" value="1" {{#if (eq row.choice "1")}}checked{{/if}} {{#unless isEditMode}}disabled{{/unless}}>
                                    </div>
                                    <div class="usage-field">
                                        <label>元2（{{row.val2}}）</label>
                                        <input type="radio" name="system.combine.params.{{row.key}}" value="2" {{#if (eq row.choice "2")}}checked{{/if}} {{#unless isEditMode}}disabled{{/unless}}>
                                    </div>
                                </div>
                            </div>
                            {{/each}}
                        </div>
                        {{/if}}

                        {{#if combine.merged}}
                        <div class="combine-preview">
                            <div class="combine-preview__title">コンバインプレビュー</div>
                            <div class="style-skill-display style-skill-display-grid">
                                <div><label>名称：</label><span>{{combine.merged.name}}（コンバイン）</span></div>
                                <div class="full-width-row"><label>分類：</label><span>{{combine.merged.category}}</span></div>
                                <div><label>常備化経験点：</label><span>{{combine.merged.preserveExpTotal}}</span></div>
                                <div><label>隠：</label><span>{{combine.merged.hide}}</span></div>
                                <div><label>電制：</label><span>{{combine.merged.hack}}</span></div>
                                <div class="full-width-row"><label>部位：</label><span>{{combine.merged.part}}</span></div>
                            </div>
                        </div>
                        {{/if}}

                        {{#if combine.isActive}}
                        <div class="form-group">
                            <button type="button" class="tnx-btn" data-action="deactivateCombine">
                                <i class="fas fa-unlink"></i> コンバイン解除
                            </button>
                        </div>
                        {{/if}}
                    </div>
                </fieldset>
                {{/if}}

                {{#if hasSlots}}
                <fieldset class="tnx-fieldset">
                    <legend>スロット</legend>
                    <div class="tnx-form-field">
                        {{#each system.slots as |pool|}}
                            <div class="form-group">
                                <label>{{lookup ../options.slotKinds pool.kind}}</label>
                                <div class="form-fields {{#if (eq pool.count.mode "value")}}split-fields{{/if}}">
                                    <select class="slot-mode-select" data-kind="{{pool.kind}}">
                                        {{selectOptions ../options.noneValueMode selected=pool.count.mode}}
                                    </select>
                                    {{#if (eq pool.count.mode "value")}}
                                        <div class="number-input-spinner skill-sheet-spinner">
                                            <button type="button" class="tnx-btn" data-action="decrementSlot" data-kind="{{pool.kind}}">-</button>
                                            <input type="number" value="{{pool.count.value}}" min="0" data-slot-kind="{{pool.kind}}">
                                            <button type="button" class="tnx-btn" data-action="incrementSlot" data-kind="{{pool.kind}}">+</button>
                                        </div>
                                    {{/if}}
                                </div>
                            </div>
                        {{/each}}
                    </div>
                </fieldset>
                {{/if}}

                <fieldset class="tnx-fieldset">
                    <legend>アウトフィット 詳細設定</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>購入値</label>
                            <div class="form-fields {{#if (eq system.buy.mode "value")}}split-fields{{/if}}">
                                <select name="system.buy.mode">
                                    {{selectOptions options.buyHideMode selected=system.buy.mode}}
                                </select>
                                {{#if (eq system.buy.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.buy.value">-</button>
                                        <input type="number" name="system.buy.value" value="{{system.buy.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.buy.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>

                        <div class="form-group">
                            <label>常備化経験点</label>
                            <div class="form-fields {{#if (eq system.preserveExp.mode "value")}}split-fields{{/if}}">
                                <select name="system.preserveExp.mode">
                                    {{selectOptions options.noneValueMode selected=system.preserveExp.mode}}
                                </select>
                                {{#if (eq system.preserveExp.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.preserveExp.value">-</button>
                                        <input type="number" name="system.preserveExp.value" value="{{system.preserveExp.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.preserveExp.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>

                        {{#if system.isConsumption}}
                            <div class="form-group">
                                <label>常備化個数</label>
                                <div class="number-input-spinner skill-sheet-spinner">
                                    <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.quantity.max" data-min="0">-</button>
                                    <input type="number" name="system.quantity.max" value="{{system.quantity.max}}" min="0">
                                    <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.quantity.max">+</button>
                                </div>
                            </div>
                        {{/if}}

                        <div class="form-group">
                            <label>隠匿値</label>
                            <div class="form-fields {{#if (eq system.hide.mode "value")}}split-fields{{/if}}">
                                <select name="system.hide.mode">
                                    {{selectOptions options.buyHideMode selected=system.hide.mode}}
                                </select>
                                {{#if (eq system.hide.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.hide.value">-</button>
                                        <input type="number" name="system.hide.value" value="{{system.hide.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.hide.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>

                        {{#unless isResidence}}
                        <div class="form-group">
                            <label>危険値</label>
                            <div class="form-fields {{#if (eq system.appearancePenalty.mode "value")}}split-fields{{/if}}">
                                <select name="system.appearancePenalty.mode">
                                    {{selectOptions options.appearancePenaltyMode selected=system.appearancePenalty.mode}}
                                </select>
                                {{#if (eq system.appearancePenalty.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.appearancePenalty.value">-</button>
                                        <input type="number" name="system.appearancePenalty.value" value="{{system.appearancePenalty.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.appearancePenalty.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                        {{/unless}}

                        {{#unless (or isIanus isResidence)}}
                        <div class="form-group">
                            <label>電脳制御値</label>
                            <div class="form-fields {{#if (eq system.hack.mode "value")}}split-fields{{/if}}">
                                <select name="system.hack.mode">
                                    {{selectOptions options.hackMode selected=system.hack.mode}}
                                </select>
                                {{#if (eq system.hack.mode "value")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" class="tnx-btn" data-action="decrementField" data-field="system.hack.value">-</button>
                                        <input type="number" name="system.hack.value" value="{{system.hack.value}}">
                                        <button type="button" class="tnx-btn" data-action="incrementField" data-field="system.hack.value">+</button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                        {{/unless}}

                        {{!-- 部位は独立 fieldset へ分離(下記「部位」legend。フェーズ10) --}}

                        {{!-- タイミング(選択肢はスタイル技能と共通だが、アウトフィットは一つのみ) --}}
                        <div class="form-group">
                            <label>タイミング</label>
                            <div class="form-fields {{#if (or (eq system.timing.value "action") (eq system.timing.value "process") (eq system.timing.value "other"))}}split-fields{{/if}}">
                                <select name="system.timing.value">
                                    {{selectOptions options.timing selected=system.timing.value}}
                                </select>
                                {{#if (eq system.timing.value "other")}}
                                    <input type="text" name="system.timing.timingOther" value="{{system.timing.timingOther}}" placeholder="タイミングを入力"/>
                                {{/if}}
                                {{#if (eq system.timing.value "action")}}
                                    <select name="system.timing.actionName">
                                        {{selectOptions options.actions selected=system.timing.actionName}}
                                    </select>
                                {{/if}}
                                {{#if (eq system.timing.value "process")}}
                                    <select name="system.timing.processName">
                                        {{selectOptions options.processes selected=system.timing.processName}}
                                    </select>
                                {{/if}}
                            </div>
                        </div>

                        <div class="form-group">
                            <label>専用</label>
                            <input type="text" name="system.exclusive" value="{{system.exclusive}}" placeholder="専用スタイル・ワークス"/>
                        </div>

                        {{!-- 使用回数(スタイル技能と同形。数値入力はスピナー不使用の例外) --}}
                        <div class="form-group">
                            <label for="isLimit-{{item._id}}">使用回数に制限あり</label>
                            <input type="checkbox" name="system.uses.isLimit" id="isLimit-{{item._id}}" {{checked system.uses.isLimit}}>
                        </div>
                        {{#if system.uses.isLimit}}
                            <div class="form-group">
                                <label>種別</label>
                                <select name="system.uses.type">
                                    {{selectOptions options.usesType selected=system.uses.type}}
                                </select>
                            </div>
                            <div class="form-group usage-limit-group">
                                <label>使用回数</label>
                                <div class="usage-inputs">
                                    <div class="usage-field">
                                        <label>消費済み</label>
                                        <input type="number" name="system.uses.spent" value="{{system.uses.spent}}">
                                    </div>
                                    <span class="usage-separator">/</span>
                                    <div class="usage-field">
                                        <label>最大値</label>
                                        <input type="number" name="system.uses.max" value="{{system.uses.max}}">
                                    </div>
                                </div>
                            </div>
                        {{/if}}
                    </div>
                </fieldset>

                {{!-- 部位(独立 legend・行=ブロックカード・D&D 消費 UI 参考。フェーズ10) --}}
                <fieldset class="tnx-fieldset tnx-part-fieldset">
                    <legend>
                        部位
                        <a class="tnx-part-add" title="行を追加"><i class="fas fa-plus"></i></a>
                    </legend>

                    {{#if partMultiRow}}
                    <div class="tnx-part-relation">
                        <label>結合</label>
                        <select name="system.partRelation">
                            {{selectOptions partRelationChoices selected=partRelation}}
                        </select>
                    </div>
                    {{/if}}

                    {{#if partBodyDatalist.length}}
                    <datalist id="tnx-part-bodylist">
                        {{#each partBodyDatalist}}<option value="{{this}}"></option>{{/each}}
                    </datalist>
                    {{/if}}

                    <div class="tnx-part-cards">
                        {{#each partRows as |row|}}
                        <div class="tnx-part-card" data-part-row data-index="{{row.idx}}">
                            <div class="tnx-part-card-top">
                                <div class="tnx-part-field tnx-part-kind">
                                    <label>種別</label>
                                    <select data-part-field="kind" data-index="{{row.idx}}">
                                        {{selectOptions ../partKindChoices selected=row.kind}}
                                    </select>
                                </div>
                                {{#if row.showSlots}}
                                <div class="tnx-part-field tnx-part-slots">
                                    <label>消費数 <i class="fas fa-circle-question" title="占有するスロット数（0＝非消費）"></i></label>
                                    <div class="number-input-spinner tnx-spinner--sm">
                                        <button type="button" class="tnx-btn" data-action="decrementPart" data-index="{{row.idx}}">－</button>
                                        <input type="number" data-part-field="slots" data-index="{{row.idx}}" value="{{row.slots}}" min="0">
                                        <button type="button" class="tnx-btn" data-action="incrementPart" data-index="{{row.idx}}">＋</button>
                                    </div>
                                </div>
                                {{/if}}
                                {{#if row.showOptional}}
                                <label class="tnx-part-optional" title="任意＝重複可・占有数に数えない">
                                    <input type="checkbox" data-part-field="isOptional" data-index="{{row.idx}}" {{checked row.isOptional}}>
                                    任意
                                </label>
                                {{/if}}
                                <a class="tnx-part-del" data-index="{{row.idx}}" title="この行を削除"><i class="fas fa-trash"></i></a>
                            </div>

                            {{#if row.isReference}}
                            <div class="tnx-part-field tnx-part-refsub">
                                <label>実部位<span class="tnx-part-note">（表示は常に「解説参照」）</span></label>
                                <select data-part-field="refSubKind" data-index="{{row.idx}}">
                                    {{selectOptions ../partRefSubChoices selected=row.refSubKind}}
                                </select>
                            </div>
                            {{/if}}

                            {{#if row.showBody}}
                            <div class="tnx-part-field tnx-part-target">
                                <label>部位</label>
                                {{#if ../partBodyChoices}}
                                <select data-part-field="value" data-index="{{row.idx}}">
                                    {{selectOptions ../partBodyChoices selected=row.value}}
                                </select>
                                {{else}}
                                <input type="text" data-part-field="value" data-index="{{row.idx}}" value="{{row.value}}" list="tnx-part-bodylist" placeholder="部位名（例: 片手持ち）">
                                {{/if}}
                            </div>
                            {{/if}}

                            {{#if row.showOption}}
                            <div class="tnx-part-option">
                                <div class="tnx-part-field">
                                    <label>大分類</label>
                                    <select data-part-field="hostMajor" data-index="{{row.idx}}">
                                        {{selectOptions ../partHostMajorChoices selected=row.hostMajor}}
                                    </select>
                                </div>
                                <div class="tnx-part-field tnx-part-minor">
                                    <label>小分類</label>
                                    <select data-part-field="hostMinor" data-index="{{row.idx}}">
                                        {{selectOptions row.minorChoices selected=row.hostMinor}}
                                    </select>
                                    <label class="tnx-part-exclude" title="この小分類『以外』を対象にする">
                                        <input type="checkbox" data-part-field="hostMinorExclude" data-index="{{row.idx}}" {{checked row.hostMinorExclude}}>
                                        除外
                                    </label>
                                </div>
                                <div class="tnx-part-field">
                                    <label>その他特徴</label>
                                    <select data-part-field="hostFeature" data-index="{{row.idx}}">
                                        {{selectOptions ../partHostFeatureChoices selected=row.hostFeature}}
                                    </select>
                                </div>
                                <div class="tnx-part-field tnx-part-target">
                                    <label>アイテム名</label>
                                    {{#if row.hostNameChoices}}
                                    <select data-part-field="hostName" data-index="{{row.idx}}">
                                        {{selectOptions row.hostNameChoices selected=row.hostName}}
                                    </select>
                                    {{else}}
                                    <input type="text" data-part-field="hostName" data-index="{{row.idx}}" value="{{row.hostName}}" placeholder="アイテム名（任意）">
                                    {{/if}}
                                </div>
                            </div>
                            {{/if}}

                            {{#if row.showOther}}
                            <div class="tnx-part-field tnx-part-target">
                                <label>内容</label>
                                <input type="text" data-part-field="value" data-index="{{row.idx}}" value="{{row.value}}" placeholder="自由記入">
                            </div>
                            {{/if}}
                        </div>
                        {{/each}}
                    </div>
                </fieldset>

            </div>
        </div>

        {{!-- 用途タブ --}}
        <div class="tab usage" data-group="primary" data-tab="usage">
            {{> "systems/tokyo-nova-axleration/templates/parts/usage-list.hbs"}}
        </div>

        {{!-- エフェクトタブ --}}
        <div class="tab effects" data-group="primary" data-tab="effects">
            {{> "systems/tokyo-nova-axleration/templates/parts/active-effects-list.hbs"}}
        </div>
    </section>
</section>
