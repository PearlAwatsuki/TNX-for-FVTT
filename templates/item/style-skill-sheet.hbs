<section class="{{cssClass}}">
    {{!-- ヘッダーエリア --}}
    <header class="sheet-header skill-header">
        <img class="profile-img" src="{{item.img}}" data-edit="img" data-action="editImage" title="{{item.name}}"/>
        <div class="header-fields">
            <h1 class="charname-container">
                {{#if isEditMode}}
                    <input class="furigana-input" name="system.furigana" type="text" value="{{system.furigana}}" placeholder="フリガナ" />
                    <input class="itemname-input" name="name" type="text" value="{{item.name}}" placeholder="技能"/>
                {{else}}
                    <span class="furigana-view">{{system.furigana}}</span>
                    <span class="charname-view">{{tnxDecoratedName item}}</span>
                {{/if}}
            </h1>
            
            <div class="suit-selection">
                {{#each TNX.SUITS as |suitData key|}}
                    <label for="suit-{{../item.id}}-{{key}}" class="suit-icon" title="{{suitData.label}}">
                        <input type="checkbox" id="suit-{{../item.id}}-{{key}}" name="system.suits.{{key}}" {{checked (lookup ../system.suits key)}} {{#if suitData.disabled}}disabled{{/if}} {{#if (eq item.system.generalSkill.initialSkill.initialSuit key)}}disabled{{/if}}/>
                        <i class="fa-solid fa-{{key}}"></i>
                    </label>
                {{/each}}
            </div>
        </div>

        <div class="level-display">
            <label for="system.level">レベル</label>
            <input type="number" name="system.level" value="{{system.level}}" {{#if system.levelRef.enabled}}disabled title="参照先のスタイル技能のレベルで自動設定されます"{{/if}}>
        </div>
    </header>

    {{!-- タブナビゲーション --}}
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-action="tab" data-group="primary" data-tab="description">説明</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="setting">設定</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="usage">用途</a>
        <a class="item" data-action="tab" data-group="primary" data-tab="effects">エフェクト</a>
    </nav>

    {{!-- タブコンテンツ --}}
    <section class="sheet-body">

        {{!-- 説明タブ --}}
        <div class="tab description" data-group="primary" data-tab="description">
            <div class="style-skill-display">
                <div class="style-skill-display-grid">
                    <div>
                        <label>技能：</label>
                        <span>{{view.comboSkill}}</span>
                    </div>
                    <div>
                        <label>上限：</label>
                        <span>{{view.maxLevel}}</span>
                    </div>
                    <div class="full-width-row">
                        <label>タイミング：</label><span>{{view.timing}}</span>
                    </div>
                    <div>
                        <label>対象：</label>
                        <span>{{view.target}}</span>
                    </div>
                    <div>
                        <label>射程：</label>
                        <span>{{view.range}}</span>
                    </div>
                    <div>
                        <label>目標値：</label>
                        <span>{{view.targetValue}}</span>
                    </div>
                    <div>
                        <label>対決：</label>
                        <span>{{view.confrontation}}</span>
                    </div>
                </div>
            </div>

            <div class="tnx-editor-section">
                <div class="tnx-editor-section__header">
                    <label>解説</label>
                </div>
                <div class="tnx-editor-section__content">
                     {{editor enrichedDescription target="system.description" engine="prosemirror" button=true owner=owner editable=editable}}
                </div>
            </div>
        </div>

        {{!-- 設定タブ --}}
        <div class="tab setting" data-group="primary" data-tab="setting">
            <div class="settings-grid">
                <div class="form-group">
                    <label>アクション技能</label>
                    <input type="checkbox" name="system.isAction" {{checked system.isAction}}>
                </div>
                <div class="form-group">
                    <label>報酬点を使用可能</label>
                    <input type="checkbox" name="system.usesBounty" {{checked system.usesBounty}}>
                </div>
                <div class="form-group">
                    <label>組み合わせ不可 <i class="fas fa-circle-question" title="この技能を使う組み合わせ判定はできない（単独判定のみ）。用途で組み合わせ技能を追加できなくなる"></i></label>
                    <input type="checkbox" name="system.noCombo" {{checked system.noCombo}}>
                </div>
                {{!-- 分類: 技能の種別・スタイル・上限 --}}
                <fieldset class="tnx-fieldset">
                    <legend>分類</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>種別</label>
                            <select name="system.styleSkillCategory">
                                {{selectOptions options.styleSkillCategory selected=system.styleSkillCategory}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>スタイル</label>
                            <select name="system.style">
                                {{selectOptions styleChoices selected=system.style}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>特別なスタイル技能</label>
                            <select name="system.unique">
                                {{selectOptions options.unique selected=system.unique}}
                            </select>
                        </div>

                        {{!-- 上限 (変更なし) --}}
                        <div class="form-group">
                            <label>上限</label>
                            <div class="form-fields {{#if (eq system.maxLevel 'number')}}split-fields{{/if}}">
                                <select name="system.maxLevel">
                                    {{selectOptions options.maxLevel selected=system.maxLevel}}
                                </select>
                                
                                {{!-- 数値の場合: スピナー表示 --}}
                                {{#if (eq system.maxLevel "number")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" data-action="decrementMaxLevel" class="tnx-btn">-</button>
                                        <input type="number" name="system.maxLevelNumber" value="{{system.maxLevelNumber}}"/>
                                        <button type="button" data-action="incrementMaxLevel" class="tnx-btn">+</button>
                                    </div>
                                {{/if}}

                                {{!-- その他の場合: テキスト入力 --}}
                                {{#if (eq system.maxLevel "other")}}
                                    <input type="text" name="system.maxLevelOther" value="{{system.maxLevelOther}}" placeholder="上限を入力"/>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </fieldset>

                {{!-- 発動: 用途の発動パラメータ --}}
                <fieldset class="tnx-fieldset">
                    <legend>発動</legend>
                    <div class="tnx-form-field">
                        {{!-- タイミング (Timing) --}}
                        <div class="form-group align-start">
                            <label>タイミング</label>
                            <div class="form-fields-column">
                                {{#each system.timing as |t idx|}}
                                <div class="array-row">
                                    <select name="system.timing.{{idx}}.value">
                                        {{selectOptions ../options.timing selected=t.value}}
                                    </select>

                                    {{!-- 詳細入力 --}}
                                    {{#if (eq t.value "other")}}
                                        <input type="text" name="system.timing.{{idx}}.timingOther" value="{{t.timingOther}}" placeholder="タイミングを入力"/>
                                    {{/if}}
                                    {{#if (eq t.value "action")}}
                                        <select name="system.timing.{{idx}}.actionName">
                                            {{selectOptions ../options.actions selected=t.actionName}}
                                        </select>
                                    {{/if}}
                                    {{#if (eq t.value "process")}}
                                        <select name="system.timing.{{idx}}.processName">
                                            {{selectOptions ../options.processes selected=t.processName}}
                                        </select>
                                    {{/if}}

                                    <div class="row-controls">
                                        {{!-- 1行目のみ追加ボタン --}}
                                        {{#if (eq idx 0)}}
                                            <a class="tnx-row-btn" data-target="timing" title="行を追加">
                                                <i class="fas fa-plus"></i>
                                            </a>
                                        {{/if}}

                                        {{!-- 2行目(index 1)以降は削除ボタン --}}
                                        {{#if (gte idx 1)}}
                                            <a class="tnx-row-btn--delete" data-target="timing" data-index="{{idx}}" title="削除">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        {{/if}}
                                    </div>
                                </div>
                                {{/each}}
                            </div>
                        </div>

                        <div class="form-group align-start">
                            <label>対象</label>
                            <div class="form-fields-stack">
                                {{!-- 1行目: ドロップダウンと入力欄 --}}
                                <div class="form-fields {{#if (eq system.target 'other')}}split-fields{{/if}}">
                                    <select name="system.target">
                                        {{selectOptions options.target selected=system.target}}
                                    </select>
                                    {{#if (eq system.target "other")}}
                                        <input type="text" name="system.targetOther" value="{{system.targetOther}}" placeholder="対象を入力"/>
                                    {{/if}}
                                </div>
                                {{!-- 2行目: チェックボックス --}}
                                <div class="checkbox-row">
                                    <label>変更不可（※）</label>
                                    <input type="checkbox" name="system.isFixedTarget" {{checked system.isFixedTarget}}>
                                </div>
                            </div>
                        </div>
                        <div class="form-group align-start">
                            <label>射程</label>
                            <div class="form-fields-stack">
                                {{!-- 1行目 --}}
                                <div class="form-fields {{#if (eq system.range 'other')}}split-fields{{/if}}">
                                    <select name="system.range">
                                        {{selectOptions options.range selected=system.range}}
                                    </select>
                                    {{!-- その他入力 --}}
                                    {{#if (eq system.range "other")}}
                                        <input type="text" name="system.rangeOther" value="{{system.rangeOther}}" placeholder="射程を入力"/>
                                    {{/if}}
                                </div>
                                {{!-- 2行目 --}}
                                <div class="checkbox-row">
                                    <label>変更不可（※）</label>
                                    <input type="checkbox" name="system.isFixedRange" {{checked system.isFixedRange}}>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>目標値</label>
                            <div class="form-fields {{#if (eq system.targetValue 'number')}}split-fields{{/if}}">
                                <select name="system.targetValue">
                                    {{selectOptions options.targetValue selected=system.targetValue}}
                                </select>
                                
                                {{!-- 数値の場合: スピナー --}}
                                {{#if (eq system.targetValue "number")}}
                                    <div class="number-input-spinner skill-sheet-spinner">
                                        <button type="button" data-action="decrementTargetValue" class="tnx-btn">-</button>
                                        <input type="number" name="system.targetValueNumber" value="{{system.targetValueNumber}}"/>
                                        <button type="button" data-action="incrementTargetValue" class="tnx-btn">+</button>
                                    </div>
                                {{/if}}

                                {{!-- その他の場合: テキスト入力 --}}
                                {{#if (eq system.targetValue "other")}}
                                    <input type="text" name="system.targetValueOther" value="{{system.targetValueOther}}" placeholder="目標値を入力"/>
                                {{/if}}
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="isLimit-{{item._id}}">使用回数に制限あり</label>
                            <input type="checkbox" name="system.uses.isLimit" id="isLimit-{{item._id}}" {{checked system.uses.isLimit}}>
                        </div>
                        {{#if system.uses.isLimit}}
                            <div class="form-group">
                                <label>種別</label>
                                <select name="system.uses.type">
                                    {{selectOptions options.usesType selected=system.uses.type}}
                                </select>
                            </div>
                            <div class="form-group usage-limit-group">
                                <label>使用回数</label>
                                <div class="usage-inputs">
                                    <div class="usage-field">
                                        <label>消費済み</label>
                                        <input type="number" name="system.uses.spent" value="{{system.uses.spent}}">
                                    </div>
                                    <span class="usage-separator">/</span>
                                    <div class="usage-field">
                                        <label>最大値</label>
                                        <input type="number" name="system.uses.max" value="{{system.uses.max}}">
                                    </div>
                                </div>
                            </div>
                        {{/if}}
                    </div>
                </fieldset>

                {{!-- 特技専用: 特技(special)でのみ使う設定 --}}
                {{#if (eq system.styleSkillCategory "special")}}
                <fieldset class="tnx-fieldset">
                    <legend>特技専用</legend>
                    <div class="tnx-form-field">
                            <div class="form-group">
                                <label for="isWorks-{{item._id}}">ワークス技能</label>
                                <input type="checkbox" name="system.special.works.value" id="isWorks-{{item._id}}" {{checked system.special.works.value}}>
                            </div>
                            {{#if system.special.works.value}}
                                <div class="form-group">
                                    <label>組織名</label>
                                    <select name="system.special.works.organization">
                                        {{selectOptions organizationChoices selected=system.special.works.organization}}
                                    </select>
                                </div>
                            {{/if}}
                            
                            <div class="form-group">
                                <label for="isSubstitute-{{item._id}}">代用可能</label>
                                <input type="checkbox" name="system.isSubstitute" id="isSubstitute-{{item._id}}" {{checked system.isSubstitute}}>
                            </div>

                            {{#if system.isSubstitute}}
                                <div class="form-group align-start">
                                    <label>代用対象</label>
                                    <div class="form-fields-column">
                                        {{#each system.substituteTarget as |target idx|}}
                                        <div class="array-row">
                                            <select name="system.substituteTarget.{{idx}}">
                                                {{selectOptions ../substituteSkillChoices selected=target}}
                                            </select>
                                            <div class="row-controls">
                                                {{#if (eq idx 0)}}
                                                <button type="button" class="tnx-row-btn" data-target="substitute" title="行を追加">
                                                    <i class="fas fa-plus"></i>
                                                </button>
                                                {{/if}}
                                                {{#if (gte idx 1)}}
                                                <button type="button" class="tnx-row-btn--delete" data-target="substitute" data-index="{{idx}}" title="削除">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                                {{/if}}
                                            </div>
                                        </div>
                                        {{/each}}
                                    </div>
                                </div>
                            {{/if}}

                            {{#if (eq system.unique "miracleChange")}}
                                <div class="form-group">
                                    <label>書き換え対象の神業</label>
                                    <input type="text" name="system.rewritingMiracleName" value="{{system.rewritingMiracleName}}" placeholder="書き換え元の神業名を入力...">
                                </div>
                           
                                <div class="form-group">
                                    <label>書き換え先</label>
                                    <div class="tnx-import-box tnx-import-box--dropzone" data-drop-area="rewriting-miracle">
                                        <span>神業アイテムをここにドロップ</span>
                                    </div>
                                </div>
                            {{/if}}
                    </div>
                </fieldset>
                {{/if}}

                {{!-- 取得・経験点: 取得方法・経験点まわり --}}
                <fieldset class="tnx-fieldset">
                    <legend>取得・経験点</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>取得と同時にアウトフィットを取得する</label>
                            <input type="checkbox" name="system.acquiresOutfit" {{checked system.acquiresOutfit}}>
                        </div>

                        {{!-- 取得・経験点 (10-3) --}}
                        <div class="form-group">
                            <label>経験点消費なしで取得可 <i class="fas fa-circle-question" title="自動習得(クロガネのフォルム等)・2技能セットの相方など、経験点を消費せず取得する技能。経験点の集計から除外する"></i></label>
                            <input type="checkbox" name="system.expFree" {{checked system.expFree}}>
                        </div>

                        {{#if (or (eq system.styleSkillCategory "secret") (eq system.styleSkillCategory "mystery"))}}
                        <div class="form-group">
                            <label>{{#if (eq system.styleSkillCategory "secret")}}秘技{{else}}奥義{{/if}}の取得数に含まない <i class="fas fa-circle-question" title="特殊な取得条件の技能を取得数の表示カウントから除外する(表示のみ・上限は強制しない)"></i></label>
                            <input type="checkbox" name="system.excludeFromCount" {{checked system.excludeFromCount}}>
                        </div>
                        {{/if}}

                        <div class="form-group">
                            <label>他スタイル技能のレベルを参照 <i class="fas fa-circle-question" title="模造技能・血脈〈魔性〉など。指定した技能のレベルでこの技能のレベル欄を上書きする(判定は通常通りそのレベルを読む)。スートは手動で選択。経験点・取得数には二重計上しない"></i></label>
                            <input type="checkbox" name="system.levelRef.enabled" {{checked system.levelRef.enabled}}>
                        </div>
                        {{#if system.levelRef.enabled}}
                        <div class="form-group">
                            <label>参照先の技能</label>
                            {{#if isOnActor}}
                                <select name="system.levelRef.key">
                                    {{selectOptions levelRefChoices selected=system.levelRef.key}}
                                </select>
                            {{else}}
                                <input type="text" name="system.levelRef.key" value="{{system.levelRef.key}}" placeholder="参照先の識別キーを入力"/>
                            {{/if}}
                        </div>
                        {{/if}}
                    </div>
                </fieldset>

                {{!-- 技能: 辞典カスケードで段階選択(2列グリッド・ラベルなし) --}}
                <fieldset class="tnx-fieldset">
                    <legend>技能 <a class="tnx-combo-add" data-target="combo" title="技能を追加"><i class="fas fa-plus"></i></a></legend>
                    <div class="tnx-form-field">
                        <div class="tnx-combo-cards">
                            {{#each system.comboSkill as |skill idx|}}
                                <div class="tnx-combo-card">
                                    <div class="tnx-combo-grid">
                                        <select name="system.comboSkill.{{idx}}.value"{{#if skill.typeFull}} class="tnx-combo-full"{{/if}}>
                                            {{selectOptions ../options.comboSkill selected=skill.value}}
                                        </select>
                                        {{#if (eq skill.value "skillName")}}
                                            {{#each skill.cascadeSteps}}
                                            <select name="system.comboSkill.{{idx}}.{{this.field}}" data-cascade-key="{{this.key}}"{{#if this.full}} class="tnx-combo-full"{{/if}}>
                                                {{selectOptions this.options selected=this.value}}
                                            </select>
                                            {{/each}}
                                        {{else if (eq skill.value "other")}}
                                            <input type="text" name="system.comboSkill.{{idx}}.name" value="{{skill.name}}" placeholder="内容を入力"/>
                                        {{/if}}
                                        {{#if (or (eq skill.value "skillName") (eq skill.value "other"))}}
                                            {{#if (gt idx 0)}}
                                            <label class="checkbox-inline tnx-combo-full" title="直前の技能と結合 (&)">
                                                <input type="checkbox" name="system.comboSkill.{{idx}}.isMandatory" {{checked skill.isMandatory}}>
                                            </label>
                                            {{/if}}
                                        {{/if}}
                                    </div>
                                    {{#if (gte idx 1)}}
                                    <a class="tnx-combo-del" data-target="combo" data-index="{{idx}}" title="削除"><i class="fas fa-trash"></i></a>
                                    {{/if}}
                                </div>
                            {{/each}}
                        </div>
                    </div>
                </fieldset>

                {{!-- 対決: 技能セクションと同形。「技能名」「技能名※」で辞典カスケード(技能名※は表示で ※ を付す) --}}
                <fieldset class="tnx-fieldset">
                    <legend>対決 <a class="tnx-combo-add" data-target="confrontation" title="対決を追加"><i class="fas fa-plus"></i></a></legend>
                    <div class="tnx-form-field">
                        <div class="tnx-combo-cards">
                            {{#each system.confrontation as |c idx|}}
                                <div class="tnx-combo-card">
                                    <div class="tnx-combo-grid">
                                        <select name="system.confrontation.{{idx}}.value"{{#if c.typeFull}} class="tnx-combo-full"{{/if}}>
                                            {{selectOptions ../options.confrontation selected=c.value}}
                                        </select>
                                        {{#if (or (eq c.value "skillName") (eq c.value "skillNameAsterisk"))}}
                                            {{#each c.cascadeSteps}}
                                            <select name="system.confrontation.{{idx}}.{{this.field}}" data-cascade-key="{{this.key}}"{{#if this.full}} class="tnx-combo-full"{{/if}}>
                                                {{selectOptions this.options selected=this.value}}
                                            </select>
                                            {{/each}}
                                        {{else if (eq c.value "other")}}
                                            <input type="text" name="system.confrontation.{{idx}}.name" value="{{c.name}}" placeholder="内容を入力"/>
                                        {{/if}}
                                    </div>
                                    {{#if (gte idx 1)}}
                                    <a class="tnx-combo-del" data-target="confrontation" data-index="{{idx}}" title="削除"><i class="fas fa-trash"></i></a>
                                    {{/if}}
                                </div>
                            {{/each}}
                        </div>
                    </div>
                </fieldset>

                {{!-- 自動取得: acquiresOutfit か 特別なスタイル技能=トループ取得技能 のとき表示。取得アイテム/アクターは各条件で出し分け --}}
                {{#if showAutoAcquire}}
                <fieldset class="tnx-fieldset">
                    <legend>自動取得（取得時）</legend>

                    {{#if system.acquiresOutfit}}
                    <div class="form-group">
                        <label>武器使用義務 <i class="fas fa-circle-question" title="取得武器でこの技能の判定をしなければならない（オフ＝取得のみ・使用は任意）"></i></label>
                        <input type="checkbox" name="system.weaponUseMandatory" {{checked system.weaponUseMandatory}}>
                    </div>

                    <div class="form-group align-start">
                        <label>取得アイテム</label>
                        <div class="style-acquire-list">
                            {{#each autoAcquireItems}}
                            <button type="button" class="tnx-linked-btn{{#if this.missing}} is-missing{{/if}}" data-action="viewAcquireRef" data-acquire="items" data-index="{{@index}}" data-context-menu="acquire-ref">
                                {{#if this.img}}<img src="{{this.img}}" class="tnx-linked-btn__icon"/>{{/if}}
                                <span class="tnx-linked-btn__label">{{this.name}}{{#if this.missing}}（削除済み）{{/if}}</span>
                            </button>
                            {{/each}}
                            <div class="tnx-import-box tnx-import-box--dropzone" data-drop-area="acquire-items">
                                <span>アイテムをここにドロップ</span>
                            </div>
                        </div>
                    </div>
                    {{/if}}

                    {{#if (eq system.unique "troopAcquire")}}
                    <div class="form-group align-start">
                        <label>取得アクター</label>
                        <div class="style-acquire-list">
                            {{#each autoAcquireActors}}
                            <button type="button" class="tnx-linked-btn{{#if this.missing}} is-missing{{/if}}" data-action="viewAcquireRef" data-acquire="actors" data-index="{{@index}}" data-context-menu="acquire-ref">
                                {{#if this.img}}<img src="{{this.img}}" class="tnx-linked-btn__icon"/>{{/if}}
                                <span class="tnx-linked-btn__label">{{this.name}}{{#if this.missing}}（削除済み）{{/if}}</span>
                            </button>
                            {{/each}}
                            {{!-- トループは1つのみ。未設定のときだけドロップ枠を出す（差し替えは削除→再ドロップ） --}}
                            {{#unless autoAcquireActors.length}}
                            <div class="tnx-import-box tnx-import-box--dropzone" data-drop-area="acquire-actors">
                                <span>アクターをここにドロップ（1つのみ）</span>
                            </div>
                            {{/unless}}
                        </div>
                    </div>
                    {{/if}}
                </fieldset>
                {{/if}}

                <fieldset class="tnx-fieldset">
                    <legend>識別キー</legend>
                    <div class="tnx-form-field">
                        <div class="form-group">
                            <label>識別キー</label>
                            <input type="text" name="system.identificationKey" value="{{system.identificationKey}}" placeholder="識別キーを入力"/>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>

        {{!-- 用途タブ --}}
        <div class="tab usage" data-group="primary" data-tab="usage">
            {{> "systems/tokyo-nova-axleration/templates/parts/usage-list.hbs"}}
        </div>

        {{!-- エフェクトタブ --}}
        <div class="tab effects" data-group="primary" data-tab="effects">
            {{> "systems/tokyo-nova-axleration/templates/parts/active-effects-list.hbs"}}
        </div>

    </section>
</section>