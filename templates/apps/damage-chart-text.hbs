<div class="tnx-dct-root">
    <nav class="tnx-dct-tabs">
        {{#each categories}}
        <a class="tnx-dct-tab {{#if active}}active{{/if}}" data-action="switchTab" data-tab="{{key}}">{{label}}ダメージ</a>
        {{/each}}
    </nav>

    <div class="tnx-dct-body">
        {{#each categories}}
        <section data-tab-content="{{key}}" {{#unless active}}hidden{{/unless}}>
            {{#each rows}}
            <div class="form-group tnx-dct-row">
                <label>{{tier}}　{{name}}</label>
                <div class="form-fields">
                    <input type="text" name="{{../key}}.{{tier}}" value="{{text}}">
                </div>
            </div>
            {{/each}}
        </section>
        {{/each}}
    </div>

    <footer class="sheet-footer">
        <button type="submit" class="tnx-btn"><i class="fas fa-save"></i> 設定を保存</button>
    </footer>
</div>
